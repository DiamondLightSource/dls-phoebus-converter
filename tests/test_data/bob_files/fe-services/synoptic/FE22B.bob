				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<rules>
			<rule name="backColorAlarmRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>$(dom)-VA-SPACE-01:STA</pv_name>
			</rule>
		</rules>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
		<text></text>
