					<device>$(dom)-VA-VALVE-02</device>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<rules>
			<rule name="symbol_single_pv" prop_id="symbols[0]" out_exp="false">
				<exp bool_exp="pvSev0==3 || pvSev0==4">
					<value>fe-ui-support/symbols/vacuumValve-symbol-34_0.png</value>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
			<rule name="symbol_single_pv_1" prop_id="symbols[1]" out_exp="false">
				<exp bool_exp="pvSev0==3 || pvSev0==4">
					<value>fe-ui-support/symbols/vacuumValve-symbol-34_0.png</value>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
			<rule name="symbol_single_pv_2" prop_id="symbols[2]" out_exp="false">
				<exp bool_exp="pvSev0==3 || pvSev0==4">
					<value>fe-ui-support/symbols/vacuumValve-symbol-34_0.png</value>
				</exp>
				<pv_name>$(pv_name)</pv_name>
