			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</on_color>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<line_color>
			<color red="150" green="150" blue="150"></color>
		</line_color>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>acc-ui-support/bob/devIocStats/ioc_stats_softdls.bob</file>
				<macros>
					<ioc>$(dom)-MO-IOC-01</ioc>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<rules>
			<rule name="visibility_rule" prop_id="visible" out_exp="false">
				<exp bool_exp="(pv0 &amp; 1024)==1024">
					<value>true</value>
				</exp>
				<exp bool_exp="(pv0 &amp; 1024)!=1024">
					<value>false</value>
				</exp>
				<pv_name>$(dom)-CS-IOC-01:SUM_CFG</pv_name>
			</rule>
			<rule name="notProdRule" prop_id="bulb_border_color" out_exp="false">
				<exp bool_exp="((pv0 &amp; 8192)!=8192) &amp;&amp; pv1==1">
					<value>&lt;color blue="0" green="241" name="Minor" red="255"/&gt;</value>
				</exp>
				<exp bool_exp="((pv0 &amp; 8192)==8192) || pv1==0">
					<value>&lt;color blue="150" green="150" red="150"/&gt;</value>
				</exp>
				<pv_name>$(dom)-CS-IOC-01:SUM_CFG</pv_name>
				<pv_name>sim://ramp(0,1,1,0.5)</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>Action Button_7</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>fe-ui-support/bob/procServControl/procServControl.bob</file>
				<macros>
					<PROCSERV>$(dom)-PY-IOC-01</PROCSERV>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>PY</text>
		<x>1071</x>
		<width>30</width>
		<height>20</height>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Button: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<rules>
			<rule name="visibility_rule" prop_id="visible" out_exp="false">
				<exp bool_exp="((pv0 &amp; 256) ==256) &amp;&amp; ((pv0 &amp; 2048) ==2048) ">
					<value>true</value>
				</exp>
				<exp bool_exp="((pv0 &amp; 256)!=256) || ((pv0 &amp; 2048)!=2048)">
					<value>false</value>
				</exp>
				<pv_name>$(dom)-CS-IOC-01:SUM_CFG</pv_name>
			</rule>
		</rules>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
