<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>$(dom)</name>
	<x>543</x>
	<y>581</y>
	<height>400</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="action_button" version="3.0.0">
		<name>Action Button</name>
		<actions>
			<action type="command">
				<description>Execute Command</description>
				<command>/bin/bash -c "$(configure-ioc s -p fe-css-wrapper-gui)/scripts/FE_dls_pmac_control.sh $(brick_ip) $(dom)-CS-RSERV-01 $(pmac_port)"</command>
			</action>
		</actions>
		<text>Control</text>
		<y>66</y>
		<width>120</width>
		<height>25</height>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Button: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>Action Button_2</name>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open Display</description>
				<file>fe-ui-support/bob/deltaTauPLCStat/Global.bob</file>
				<target>standalone</target>
			</action>
		</actions>
		<text>PLCs</text>
		<y>33</y>
		<width>120</width>
		<height>25</height>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Button: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>Action Button_2</name>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open Display</description>
				<file>fe-ui-support/bob/pmac/pmac_controller.bob</file>
				<macros>
					<pmac>$(dom)-MO-STEP-0$(brick_no)</pmac>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>Status</text>
		<width>120</width>
		<height>25</height>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Button: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="group" version="3.0.0">
		<name>Grouping Container</name>
		<x>134</x>
		<y>36</y>
		<width>116</width>
		<height>20</height>
		<style>3</style>
		<foreground_color>
			<color red="0" green="128" blue="255"></color>
		</foreground_color>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<transparent>true</transparent>
		<actions></actions>
		<widget type="led" version="2.0.0">
			<name>LED</name>
			<pv_name>$(dom)-MO-PLCST-01:STEP_PLCS_OK</pv_name>
			<x>96</x>
			<off_color>
				<color name="Green LED: Off" red="0" green="96" blue="0"></color>
			</off_color>
			<on_color>
				<color name="Green LED: On" red="0" green="255" blue="0"></color>
			</on_color>
			<foreground_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</foreground_color>
			<line_color>
				<color red="150" green="150" blue="150"></color>
			</line_color>
			<actions></actions>
			<border_alarm_sensitive>false</border_alarm_sensitive>
		</widget>
		<widget type="label" version="2.0.0">
			<name>Label</name>
			<text>All PLCs OK</text>
			<y>1</y>
			<width>81</width>
			<height>18</height>
			<foreground_color>
				<color name="Text: FG" red="0" green="0" blue="0"></color>
			</foreground_color>
			<background_color>
				<color name="Canvas" red="200" green="200" blue="200"></color>
			</background_color>
			<horizontal_alignment>1</horizontal_alignment>
			<vertical_alignment>1</vertical_alignment>
			<auto_size>true</auto_size>
			<wrap_words>false</wrap_words>
			<actions></actions>
			<border_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</border_color>
		</widget>
	</widget>
</display>