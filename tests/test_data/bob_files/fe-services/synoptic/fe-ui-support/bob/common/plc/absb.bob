<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>$(dom)</name>
	<x>543</x>
	<y>581</y>
	<width>473</width>
	<height>211</height>
	<background_color>
		<color name="Grey 75%" red="192" green="192" blue="192"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="group" version="3.0.0">
		<name>Grouping Container</name>
		<width>473</width>
		<height>211</height>
		<style>3</style>
		<foreground_color>
			<color red="0" green="128" blue="255"></color>
		</foreground_color>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<transparent>true</transparent>
		<actions></actions>
		<widget type="symbol" version="2.0.0">
			<name>Edm Symbol Widget</name>
			<symbols>
				<symbol>../../images/absorber-xsection.png</symbol>
			</symbols>
			<x>119</x>
			<y>55</y>
			<width>354</width>
			<height>104</height>
			<background_color>
				<color red="0" green="0" blue="255"></color>
			</background_color>
			<actions></actions>
			<tooltip>$(pv_name)
$(pv_value)</tooltip>
		</widget>
		<widget type="label" version="2.0.0">
			<name>Label_4</name>
			<text>First Absorber</text>
			<y>97</y>
			<width>120</width>
			<foreground_color>
				<color name="Text: FG" red="0" green="0" blue="0"></color>
			</foreground_color>
			<background_color>
				<color name="Canvas" red="200" green="200" blue="200"></color>
			</background_color>
			<horizontal_alignment>1</horizontal_alignment>
			<vertical_alignment>1</vertical_alignment>
			<wrap_words>false</wrap_words>
			<actions></actions>
			<border_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</border_color>
		</widget>
		<widget type="progressbar" version="2.0.0">
			<name>Progress Bar</name>
			<pv_name>$(dom)-RS-ABSB-01:TMON03$(suffix)</pv_name>
			<x>119</x>
			<y>25</y>
			<width>122</width>
			<height>28</height>
			<fill_color>
				<color red="0" green="0" blue="255"></color>
			</fill_color>
			<background_color>
				<color red="200" green="200" blue="200"></color>
			</background_color>
			<actions>
				<action type="open_display">
					<description>Open Display</description>
					<file>../../../dlsPLC/temperature-config.opi</file>
					<macros>
						<temp>$(pv_name)</temp>
					</macros>
					<target>standalone</target>
				</action>
			</actions>
			<scripts></scripts>
			<border_alarm_sensitive>false</border_alarm_sensitive>
			<limits_from_pv>false</limits_from_pv>
		</widget>
