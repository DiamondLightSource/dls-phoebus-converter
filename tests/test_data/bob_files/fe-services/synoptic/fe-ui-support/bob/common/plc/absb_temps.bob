<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>$(dom)</name>
	<x>543</x>
	<y>581</y>
	<width>600</width>
	<height>55</height>
	<background_color>
		<color name="Grey 75%" red="192" green="192" blue="192"></color>
