<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<x>543</x>
	<y>581</y>
	<width>260</width>
	<height>20</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="action_button" version="3.0.0">
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open Display</description>
				<file>fe-ui-support/bob/motor/motor.bob</file>
				<target>standalone</target>
			</action>
		</actions>
		<text>$(desc)</text>
		<width>54</width>
		<height>20</height>
		<foreground_color>
			<color name="Related Display: FG" red="128" green="64" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>Stop
$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>Readback</name>
		<pv_name>$(motor).RBV</pv_name>
		<x>53</x>
		<width>126</width>
		<font>
			<font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Monitor: FG" red="96" green="255" blue="96"></color>
		</foreground_color>
		<background_color>
			<color name="Monitor: BG" red="64" green="64" blue="64"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<tooltip>Readback
$(pv_name)
$(pv_value)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="led" version="2.0.0">
		<name>LED</name>
		<pv_name>$(motor).SEVR</pv_name>
		<x>192</x>
		<off_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</on_color>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<line_color>
			<color red="150" green="150" blue="150"></color>
		</line_color>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="led" version="2.0.0">
		<name>LED_1</name>
		<pv_name>$(motor).DMOV</pv_name>
		<x>236</x>
		<off_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<line_color>
			<color red="150" green="150" blue="150"></color>
		</line_color>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
</display>