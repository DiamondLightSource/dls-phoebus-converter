<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Interlock PLC Override</name>
	<x>33</x>
	<y>1081</y>
	<width>200</width>
	<height>60</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<x>5</x>
		<y>10</y>
		<width>186</width>
		<height>46</height>
		<line_width>1</line_width>
		<line_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
	</widget>
	<widget type="byte_monitor" version="2.0.0">
		<name>EDM Byte</name>
		<pv_name>$(P):OVERRIDE</pv_name>
		<x>85</x>
		<y>25</y>
		<width>21</width>
		<height>21</height>
		<numBits>1</numBits>
		<horizontal>false</horizontal>
		<square>true</square>
		<off_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<rules>
			<rule name="onColorAlarm" prop_id="on_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>$(P):OVERRIDE</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="byte_monitor" version="2.0.0">
		<name>EDM Byte</name>
		<pv_name>$(P):REMOVEREQUEST.A</pv_name>
		<x>105</x>
		<y>25</y>
		<width>21</width>
		<height>21</height>
		<numBits>1</numBits>
		<horizontal>false</horizontal>
		<square>true</square>
		<off_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<rules>
			<rule name="onColorAlarm" prop_id="on_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>$(P):REMOVEREQUEST.A</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./override.bob</file>
				<macros>
					<P>$(P)</P>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>Setup</text>
		<x>130</x>
		<y>25</y>
		<width>56</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="BOLD" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Related Display: FG" red="128" green="64" blue="32"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="combo" version="2.0.0">
		<name>EDM menu button</name>
		<pv_name>$(P):REQUEST</pv_name>
		<x>10</x>
		<y>25</y>
		<width>71</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM Text Update</name>
		<pv_name>$(P):REQUEST.DESC</pv_name>
		<x>6</x>
		<y>1</y>
		<width>179</width>
		<height>14</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 50%" red="128" green="128" blue="128"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_width>1</border_width>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
</display>