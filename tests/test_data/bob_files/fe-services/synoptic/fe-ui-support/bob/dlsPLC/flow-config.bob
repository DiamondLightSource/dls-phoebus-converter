<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Device - $(P)</name>
	<x>800</x>
	<y>749</y>
	<width>255</width>
	<height>115</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>EXIT</text>
		<x>135</x>
		<y>85</y>
		<width>116</width>
		<height>26</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="18.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="192" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>EDM Symbol</name>
		<file>symbols-traffic-light-symbol.bob</file>
		<x>85</x>
		<y>55</y>
		<width>20</width>
		<height>20</height>
		<group_name>1</group_name>
		<transparent>true</transparent>
		<rules>
			<rule name="symbol_binary_truth_table" prop_id="group_name" out_exp="false">
				<exp bool_exp="((pv0==0?0:1)*1.0)&gt;=-1.0&amp;&amp;((pv0==0?0:1)*1.0)&lt;0.0">
					<value>0</value>
				</exp>
				<exp bool_exp="((pv0==0?0:1)*1.0)&gt;=1.0&amp;&amp;((pv0==0?0:1)*1.0)&lt;2.0">
					<value>1</value>
				</exp>
				<exp bool_exp="((pv0==0?0:1)*1.0)&gt;=0.0&amp;&amp;((pv0==0?0:1)*1.0)&lt;0.0">
					<value>2</value>
				</exp>
				<exp bool_exp="((pv0==0?0:1)*1.0)&gt;=0.0&amp;&amp;((pv0==0?0:1)*1.0)&lt;1.0">
					<value>3</value>
				</exp>
				<exp bool_exp="true">
					<value>0</value>
				</exp>
				<pv_name>$(flow):LO</pv_name>
			</rule>
		</rules>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>EDM Symbol</name>
		<file>symbols-traffic-light-symbol.bob</file>
		<x>225</x>
		<y>55</y>
		<width>20</width>
		<height>20</height>
		<group_name>1</group_name>
		<transparent>true</transparent>
		<rules>
			<rule name="symbol_binary_truth_table" prop_id="group_name" out_exp="false">
				<exp bool_exp="((pv0==0?0:1)*1.0)&gt;=-1.0&amp;&amp;((pv0==0?0:1)*1.0)&lt;0.0">
					<value>0</value>
				</exp>
				<exp bool_exp="((pv0==0?0:1)*1.0)&gt;=1.0&amp;&amp;((pv0==0?0:1)*1.0)&lt;2.0">
					<value>1</value>
				</exp>
				<exp bool_exp="((pv0==0?0:1)*1.0)&gt;=0.0&amp;&amp;((pv0==0?0:1)*1.0)&lt;0.0">
					<value>2</value>
				</exp>
				<exp bool_exp="((pv0==0?0:1)*1.0)&gt;=0.0&amp;&amp;((pv0==0?0:1)*1.0)&lt;1.0">
					<value>3</value>
				</exp>
				<exp bool_exp="true">
					<value>0</value>
				</exp>
				<pv_name>$(flow):LOLO</pv_name>
			</rule>
		</rules>
	</widget>
	<widget type="label" version="2.0.0">
