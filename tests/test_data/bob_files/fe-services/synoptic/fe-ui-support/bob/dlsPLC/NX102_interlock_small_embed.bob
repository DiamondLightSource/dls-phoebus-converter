<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<width>140</width>
	<height>46</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="textupdate" version="2.0.0">
		<name>Status</name>
		<pv_name>$(device)$(interlock):NAME</pv_name>
		<width>141</width>
		<font>
			<font name="Label Small" family="Liberation Sans" style="REGULAR" size="12.871287128712872"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="led" version="2.0.0">
		<name>LED_2</name>
		<x>30</x>
		<y>25</y>
		<off_color>
			<color name="Red LED: On" red="255" green="0" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<line_color>
			<color red="150" green="150" blue="150"></color>
		</line_color>
		<actions></actions>
		<rules>
			<rule name="LEDState" prop_id="pv_value" out_exp="true">
				<exp bool_exp="pv0==65535 &amp;&amp; pv1==65535 &amp;&amp; pv2==65535">
					<expression>1</expression>
				</exp>
				<exp bool_exp="pv0!=65535 || pv1!=65535 || pv2!=65535">
					<expression>0</expression>
				</exp>
				<pv_name>$(device)$(interlock):RAWILK</pv_name>
				<pv_name>$(device)$(interlock):ILK</pv_name>
				<pv_name>$(device)$(interlock):INIILK</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>Reset</name>
		<actions>
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(device)$(interlock):RESET.PROC</pv_name>
		<text>Reset</text>
		<x>55</x>
		<y>25</y>
		<width>86</width>
		<height>20</height>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>Icon</name>
		<symbols>
			<symbol>symbol/interlock.png</symbol>
		</symbols>
		<y>22</y>
		<width>24</width>
		<height>24</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open Display</description>
				<file>NX102_interlock_small_detail.bob</file>
				<target>tab</target>
			</action>
		</actions>
		<tooltip></tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<preserve_ratio>false</preserve_ratio>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>Image Boolean Indicator</name>
		<symbols>
			<symbol></symbol>
			<symbol></symbol>
		</symbols>
		<x>466</x>
		<y>269</y>
		<width>25</width>
		<height>22</height>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<actions></actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
		<auto_size>true</auto_size>
	</widget>
</display>