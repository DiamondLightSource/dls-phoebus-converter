<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Tooltip</name>
	<x>108</x>
	<y>589</y>
	<width>240</width>
	<height>180</height>
	<background_color>
		<color name="TI title" red="210" green="201" blue="172"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="polyline" version="2.0.0">
		<name>EDM Line</name>
		<width>242</width>
		<height>182</height>
		<points>
			<point x="1.0" y="181.0"></point>
			<point x="1.0" y="1.0"></point>
			<point x="241.0" y="1.0"></point>
		</points>
		<line_width>2</line_width>
		<line_color>
			<color name="Grey 90%" red="230" green="230" blue="230"></color>
		</line_color>
	</widget>
	<widget type="polyline" version="2.0.0">
		<name>EDM Line</name>
		<width>241</width>
		<height>181</height>
		<points>
			<point x="1.0" y="180.0"></point>
			<point x="240.0" y="180.0"></point>
			<point x="240.0" y="1.0"></point>
		</points>
		<line_width>2</line_width>
		<line_color>
			<color name="Grey 40%" red="102" green="102" blue="102"></color>
		</line_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Help</text>
		<x>85</x>
		<y>5</y>
		<width>70</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 50%" red="128" green="128" blue="128"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</border_color>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM TextInput</name>
		<pv_name>$(temp).DESC</pv_name>
		<x>5</x>
		<y>160</y>
		<width>230</width>
		<height>14</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<transparent>true</transparent>
		<show_units>false</show_units>
		<horizontal_alignment>1</horizontal_alignment>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>EDM Symbol</name>
		<file>symbols-traffic-light-symbol.bob</file>
		<x>145</x>
		<y>80</y>
		<width>20</width>
		<height>20</height>
		<group_name>1</group_name>
		<transparent>true</transparent>
		<rules>
			<rule name="symbol_single_pv" prop_id="group_name" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>0</value>
				</exp>
				<exp bool_exp="pv0&gt;=-1.0&amp;&amp;pv0&lt;0.0">
					<value>0</value>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;3.0">
					<value>1</value>
				</exp>
				<exp bool_exp="pv0&gt;=4.0&amp;&amp;pv0&lt;5.0">
					<value>2</value>
				</exp>
				<exp bool_exp="pv0&gt;=3.0&amp;&amp;pv0&lt;4.0">
					<value>3</value>
				</exp>
				<exp bool_exp="true">
					<value>0</value>
				</exp>
				<pv_name>$(temp).STAT</pv_name>
			</rule>
		</rules>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM TextInput</name>
		<pv_name>$(temp)</pv_name>
		<x>99</x>
		<y>81</y>
		<width>45</width>
		<height>18</height>
		<font>
			<font family="liberation sans" style="BOLD" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<transparent>true</transparent>
		<show_units>false</show_units>
		<horizontal_alignment>1</horizontal_alignment>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./temperature-config.bob</file>
				<macros>
					<temp>$(temp)</temp>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>$(label):</text>
		<x>75</x>
		<y>80</y>
		<width>25</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="10.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
