<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<width>640</width>
	<height>35</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="rectangle" version="2.0.0">
		<name>Rectangle</name>
		<macros>
			<pv_name></pv_name>
		</macros>
		<y>1</y>
		<width>641</width>
		<height>32</height>
		<line_width>0</line_width>
		<line_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</line_color>
		<background_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</background_color>
		<actions></actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
	</widget>
	<widget type="label" version="2.0.0">
		<name>Description</name>
		<text>$(device)</text>
		<x>5</x>
		<width>236</width>
		<height>33</height>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<actions></actions>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>rebootEN</name>
		<actions>
			<action type="write_pv">
				<description>Enable Reboot</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(device):REBOOTEN</pv_name>
		<text>Reboot Enable</text>
		<x>255</x>
		<y>5</y>
		<width>145</width>
		<height>25</height>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>reboot</name>
		<actions>
			<action type="write_pv">
				<description>Enable Reboot</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(device):REBOOT</pv_name>
		<text>Reboot</text>
		<x>455</x>
		<y>5</y>
		<width>180</width>
		<height>25</height>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<rules>
			<rule name="Visibility" prop_id="enabled" out_exp="true">
				<exp bool_exp="pv0==1">
					<expression>true</expression>
				</exp>
				<exp bool_exp="pv0==0">
					<expression>false</expression>
				</exp>
				<pv_name>$(device):REBOOTEN</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="led" version="2.0.0">
		<name>LED</name>
		<pv_name>$(device):REBOOTEN</pv_name>
		<x>410</x>
		<y>7</y>
		<off_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<line_color>
			<color red="150" green="150" blue="150"></color>
		</line_color>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
</display>