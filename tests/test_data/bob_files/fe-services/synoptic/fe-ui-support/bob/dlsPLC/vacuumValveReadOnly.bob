<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Vacuum Valve - $(device)</name>
	<x>87</x>
	<y>648</y>
	<width>224</width>
	<height>140</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(device)</text>
		<width>224</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="18.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="VA title" red="202" green="223" blue="159"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<x>8</x>
		<y>48</y>
		<width>209</width>
		<height>51</height>
		<line_width>1</line_width>
		<line_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Details</text>
		<x>8</x>
		<y>40</y>
		<width>48</width>
		<height>16</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Grey 90%" red="230" green="230" blue="230"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 50%" red="128" green="128" blue="128"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="Grey 90%" red="230" green="230" blue="230"></color>
		</border_color>
	</widget>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<x>8</x>
		<y>40</y>
		<width>49</width>
		<height>17</height>
		<line_width>1</line_width>
		<line_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</line_color>
		<background_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</background_color>
		<transparent>true</transparent>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Status</text>
		<x>16</x>
		<y>68</y>
		<width>42</width>
		<height>16</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM Text Update</name>
		<pv_name>$(device):STA</pv_name>
		<x>96</x>
		<y>64</y>
		<width>113</width>
		<height>23</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Mid Green" red="0" green="192" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Monitor: BG" red="64" green="64" blue="64"></color>
		</background_color>
		<transparent>true</transparent>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color name="Mid Green" red="0" green="192" blue="0"></color>
		</border_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>168</x>
		<y>110</y>
		<width>49</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="192" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Read Only Valve</text>
		<x>8</x>
		<y>38</y>
		<width>209</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 50%" red="128" green="128" blue="128"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
</display>