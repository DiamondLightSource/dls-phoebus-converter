<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Reboot RGA - $(device)</name>
	<x>147</x>
	<y>800</y>
	<width>215</width>
	<height>145</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<x>8</x>
		<y>48</y>
		<width>201</width>
		<height>57</height>
		<line_width>1</line_width>
		<line_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>EXIT</text>
		<x>144</x>
		<y>112</y>
		<width>65</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="192" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="bool_button" version="2.0.0">
		<name>EDM Button</name>
		<pv_name>$(device):REBOOTEN</pv_name>
		<x>16</x>
		<y>64</y>
		<width>88</width>
		<height>32</height>
		<off_label>Enable</off_label>
		<off_color>
			<color name="Button_Background" red="210" green="210" blue="210"></color>
		</off_color>
		<on_label>Enable</on_label>
		<on_color>
			<color red="168" green="168" blue="168"></color>
		</on_color>
		<show_led>false</show_led>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0==0">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Button: On" red="190" green="190" blue="190"></color>
					</value>
				</exp>
				<pv_name>$(device):REBOOTEN</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Reboot</text>
		<x>112</x>
		<y>64</y>
		<width>88</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<x>111</x>
		<y>63</y>
		<width>90</width>
		<height>34</height>
		<line_width>2</line_width>
		<line_color>
			<color name="Red" red="255" green="0" blue="0"></color>
		</line_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<transparent>true</transparent>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(device)</text>
		<width>216</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="18.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="VA title" red="202" green="223" blue="159"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Reboot RGA</text>
		<x>8</x>
		<y>40</y>
		<width>82</width>
		<height>13</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 50%" red="128" green="128" blue="128"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Message Button</name>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(device):REBOOT</pv_name>
		<text>Reboot</text>
		<x>112</x>
		<y>64</y>
		<width>88</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<rules>
			<rule name="visibleRule" prop_id="visible" out_exp="false">
				<exp bool_exp="pv0&gt;=1.0&amp;&amp; pv0&lt;2.0">
					<value>true</value>
				</exp>
				<exp bool_exp="true">
					<value>false</value>
				</exp>
				<pv_name>$(device):REBOOTEN</pv_name>
			</rule>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Grey 75%" red="192" green="192" blue="192"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(device):REBOOT</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
</display>