	<widget type="byte_monitor" version="2.0.0">
		<name>EDM Byte</name>
		<pv_name>$(P):OVERRIDE</pv_name>
		<x>10</x>
		<y>170</y>
		<width>21</width>
		<height>21</height>
		<numBits>1</numBits>
		<horizontal>false</horizontal>
		<square>true</square>
		<off_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<rules>
			<rule name="onColorAlarm" prop_id="on_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>$(P):OVERRIDE</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>EXIT</text>
		<x>140</x>
		<y>170</y>
		<width>91</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="192" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
