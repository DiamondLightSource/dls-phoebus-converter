<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Nx102 Robotdxstatus Detail</name>
	<width>360</width>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget typeId="org.csstudio.opibuilder.widgets.detailpanel" version="1.0.0">
		<widget_type>Detail Panel</widget_type>
		<font>
			<opifont.name fontName="Arial" height="11" style="0">Default</opifont.name>
		</font>
		<background_color>
			<color blue="200" green="200" name="Canvas" red="200"></color>
		</background_color>
		<foreground_color>
			<color blue="0" green="0" name="Text: FG" red="0"></color>
		</foreground_color>
		<color_odd_row_back>
			<color blue="205" green="205" name="Controller: BG" red="205"></color>
		</color_odd_row_back>
		<color_even_row_back>
			<color blue="200" green="200" name="Canvas" red="200"></color>
		</color_even_row_back>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<width>360</width>
		<vert_divider_pos>160</vert_divider_pos>
		<scale_options>
			<width_scalable>false</width_scalable>
			<height_scalable>false</height_scalable>
			<keep_wh_ratio>false</keep_wh_ratio>
		</scale_options>
		<widget typeId="org.csstudio.opibuilder.widgets.groupingContainer" version="1.0.0">
			<widget_type>Grouping Container</widget_type>
			<font>
				<opifont.name fontName="Arial" height="11" style="0">Default</opifont.name>
			</font>
			<background_color>
				<color blue="200" green="200" name="Canvas" red="200"></color>
			</background_color>
			<foreground_color>
				<color blue="0" green="0" name="Text: FG" red="0"></color>
			</foreground_color>
			<border_alarm_sensitive>false</border_alarm_sensitive>
			<border_color>
				<color blue="200" green="200" name="Canvas" red="200"></color>
			</border_color>
			<border_style>0</border_style>
			<widget typeId="org.csstudio.opibuilder.widgets.bytemonitor" version="1.0.0">
				<widget_type>Byte Monitor</widget_type>
				<border_alarm_sensitive>false</border_alarm_sensitive>
				<background_color>
					<color blue="200" green="200" name="Canvas" red="200"></color>
				</background_color>
				<foreground_color>
					<color blue="0" green="0" name="Black" red="0"></color>
				</foreground_color>
				<on_color>
					<color blue="0" green="255" name="Green LED: On" red="0"></color>
				</on_color>
				<off_color>
					<color blue="0" green="96" name="Green LED: Off" red="0"></color>
				</off_color>
				<numBits>1</numBits>
				<height>30</height>
				<horizontal>false</horizontal>
				<effect_3d>true</effect_3d>
				<square_led>false</square_led>
				<width>30</width>
				<x>35</x>
				<y>1</y>
				<scale_options>
					<width_scalable>false</width_scalable>
					<height_scalable>false</height_scalable>
					<keep_wh_ratio>false</keep_wh_ratio>
				</scale_options>
				<name>auto(statusbits|$(desc))</name>
				<pv_name>$(P)$(Q)</pv_name>
			</widget>
			<height>33</height>
		</widget>
		<row_0_row_name>$(desc)</row_0_row_name>
		<row_0_row_height>33</row_0_row_height>
		<row_0_row_tooltip>$(desc)</row_0_row_tooltip>
		<row_0_row_mode>2</row_0_row_mode>
		<row_count>1</row_count>
		<height>34</height>
	</widget>
</display>