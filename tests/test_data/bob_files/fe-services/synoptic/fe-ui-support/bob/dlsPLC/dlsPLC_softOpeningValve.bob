<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>$(name)</name>
	<width>460</width>
	<height>480</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="embedded" version="2.0.0">
		<name>auto(boyembed)</name>
		<macros>
			<DESC>$(device)</DESC>
		</macros>
		<file>vacValve_embed_box.bob</file>
		<width>360</width>
		<height>55</height>
		<resize>4</resize>
		<transparent>true</transparent>
		<actions></actions>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="group" version="3.0.0">
		<name>Grouping Container</name>
		<x>10</x>
		<y>85</y>
		<width>218</width>
		<height>380</height>
		<style>3</style>
		<foreground_color>
			<color red="0" green="128" blue="255"></color>
		</foreground_color>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<transparent>true</transparent>
		<actions></actions>
		<widget type="label" version="2.0.0">
			<name>Label_2</name>
			<macros>
				<pv_name></pv_name>
			</macros>
			<text>Latched</text>
			<width>21</width>
			<height>51</height>
			<font>
				<font family="Sans" style="REGULAR" size="7.920792079207921"></font>
			</font>
			<horizontal_alignment>1</horizontal_alignment>
			<vertical_alignment>2</vertical_alignment>
			<rotation_step>3</rotation_step>
			<wrap_words>false</wrap_words>
			<actions></actions>
			<border_color>
				<color red="0" green="128" blue="255"></color>
			</border_color>
		</widget>
		<widget type="label" version="2.0.0">
			<name>Label</name>
			<macros>
				<pv_name></pv_name>
			</macros>
			<text>Initial</text>
			<x>25</x>
			<width>21</width>
			<height>51</height>
			<font>
				<font family="Sans" style="REGULAR" size="7.920792079207921"></font>
			</font>
			<horizontal_alignment>1</horizontal_alignment>
			<vertical_alignment>2</vertical_alignment>
			<rotation_step>3</rotation_step>
			<wrap_words>false</wrap_words>
			<actions></actions>
			<border_color>
				<color red="0" green="128" blue="255"></color>
			</border_color>
		</widget>
		<widget type="label" version="2.0.0">
			<name>Label_3</name>
			<macros>
				<pv_name></pv_name>
			</macros>
			<text>Current</text>
			<x>50</x>
			<width>21</width>
			<height>51</height>
			<font>
				<font family="Sans" style="REGULAR" size="7.920792079207921"></font>
			</font>
			<horizontal_alignment>1</horizontal_alignment>
			<vertical_alignment>2</vertical_alignment>
			<rotation_step>3</rotation_step>
			<wrap_words>false</wrap_words>
			<actions></actions>
			<border_color>
				<color red="0" green="128" blue="255"></color>
			</border_color>
		</widget>
		<widget type="byte_monitor" version="2.0.0">
			<name>auto(statusbits|Interlocks Latched)</name>
			<pv_name>$(device):SOFT:ILK</pv_name>
			<y>55</y>
			<width>21</width>
			<height>325</height>
			<numBits>16</numBits>
			<bitReverse>true</bitReverse>
			<horizontal>false</horizontal>
			<square>true</square>
			<off_color>
				<color name="Red LED: On" red="255" green="0" blue="0"></color>
			</off_color>
			<on_color>
				<color name="Red LED: Off" red="96" green="0" blue="0"></color>
			</on_color>
			<foreground_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</foreground_color>
			<actions></actions>
			<border_alarm_sensitive>false</border_alarm_sensitive>
		</widget>
		<widget type="byte_monitor" version="2.0.0">
			<name>auto(statusbits|Interlocks Initial)</name>
			<pv_name>$(device):SOFT:INIILK</pv_name>
			<x>25</x>
			<y>55</y>
			<width>21</width>
			<height>325</height>
			<numBits>16</numBits>
			<bitReverse>true</bitReverse>
			<horizontal>false</horizontal>
			<square>true</square>
			<off_color>
				<color name="Yellow LED: On" red="255" green="255" blue="0"></color>
			</off_color>
			<on_color>
				<color name="Yellow LED: Off" red="96" green="96" blue="0"></color>
			</on_color>
			<foreground_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</foreground_color>
			<actions></actions>
			<border_alarm_sensitive>false</border_alarm_sensitive>
		</widget>
		<widget type="byte_monitor" version="2.0.0">
