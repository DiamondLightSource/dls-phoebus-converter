<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>$(name)</name>
	<width>460</width>
	<height>480</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="group" version="3.0.0">
		<name>$(device)</name>
		<width>360</width>
		<height>55</height>
		<widget type="embedded" version="2.0.0">
			<name>$(device)_Content</name>
			<macros>
				<DESC>$(device)</DESC>
			</macros>
			<file>vacValveSoftOpening_embed.opi</file>
			<width>330</width>
			<height>25</height>
			<resize>4</resize>
			<transparent>true</transparent>
			<actions></actions>
			<border_color>
				<color name="Text: FG" red="0" green="0" blue="0"></color>
			</border_color>
		</widget>
	</widget>
</display>