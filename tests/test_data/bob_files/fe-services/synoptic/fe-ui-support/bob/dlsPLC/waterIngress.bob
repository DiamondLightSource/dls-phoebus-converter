<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Diamond Vacuum Overview</name>
	<x>752</x>
	<y>196</y>
	<width>1250</width>
	<height>1050</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Water Ingress Overview</text>
		<width>1250</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="VA title" red="202" green="223" blue="159"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>1149</x>
		<y>1015</y>
		<width>61</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="196" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="rectangle" version="2.0.0">
		<name>Rectangle_1</name>
		<macros>
			<pv_name></pv_name>
		</macros>
		<x>53</x>
		<y>140</y>
		<width>1157</width>
		<height>37</height>
		<line_width>1</line_width>
		<line_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
		<actions></actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>2-1</text>
		<x>53</x>
		<y>151</y>
		<width>34</width>
		<height>16</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<rules>
			<rule name="backcolor_alarm" prop_id="foreground_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>SR01C-VA-GGAUG-01:P.SEVR</pv_name>
			</rule>
		</rules>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>Linking Container</name>
		<macros>
			<cell>02</cell>
			<id>01</id>
		</macros>
		<file>waterIngressCellEmbed.bob</file>
		<x>136</x>
		<y>146</y>
		<width>1043</width>
		<height>26</height>
		<resize>2</resize>
		<transparent>true</transparent>
		<actions></actions>
		<rules>
			<rule name="visibility_rule" prop_id="visible" out_exp="false">
				<exp bool_exp="(pv0 &amp; 2)==2">
					<value>true</value>
				</exp>
				<exp bool_exp="(pv0 &amp; 2)!=2">
					<value>false</value>
				</exp>
				<pv_name>SR20C-VA-WINGR-01:GLOBAL_ENABLE_MASK</pv_name>
			</rule>
		</rules>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
