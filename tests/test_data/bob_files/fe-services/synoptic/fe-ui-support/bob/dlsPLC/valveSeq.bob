	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(device)</text>
		<width>224</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="18.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="VA title" red="202" green="223" blue="159"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>168</x>
		<y>214</y>
		<width>49</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="196" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>vacuumValve.bob</file>
				<macros>
					<device>$(device)</device>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>Detail</text>
		<x>88</x>
		<y>214</y>
		<width>73</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Dark Brown" red="128" green="96" blue="32"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="2.0.0">
		<name>EDM Message Button</name>
		<pv_name>$(device):OPENSEQ</pv_name>
		<bit>-1</bit>
		<x>23</x>
		<y>159</y>
		<width>66</width>
		<height>26</height>
		<off_label>Open</off_label>
		<off_color>
			<color red="240" green="240" blue="240"></color>
		</off_color>
		<on_label>Open</on_label>
		<on_color>
			<color red="192" green="192" blue="192"></color>
		</on_color>
		<show_led>false</show_led>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(device):OPENSEQ</pv_name>
				<value>1</value>
			</action>
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(device):OPENSEQ</pv_name>
				<value>0</value>
			</action>
		</actions>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<mode>1</mode>
		<confirm_message>Are you sure you want to do this?</confirm_message>
		<text>Open</text>
	</widget>
	<widget type="action_button" version="2.0.0">
		<name>EDM Message Button</name>
		<pv_name>$(device):CON</pv_name>
		<bit>-1</bit>
		<x>111</x>
		<y>159</y>
		<width>66</width>
		<height>26</height>
		<off_label>Close</off_label>
		<off_color>
			<color red="240" green="240" blue="240"></color>
		</off_color>
		<on_label>Close</on_label>
		<on_color>
			<color red="192" green="192" blue="192"></color>
		</on_color>
		<show_led>false</show_led>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(device):CON</pv_name>
				<value>Close</value>
			</action>
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(device):CON</pv_name>
				<value>Close</value>
			</action>
		</actions>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<mode>1</mode>
		<confirm_message>Are you sure you want to do this?</confirm_message>
		<text>Close</text>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>vacuumValveInterlocks.bob</file>
				<target>standalone</target>
			</action>
		</actions>
		<text>Interlocks</text>
		<x>9</x>
		<y>214</y>
		<width>73</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Dark Brown" red="128" green="96" blue="32"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
</display>