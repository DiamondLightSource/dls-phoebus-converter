<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<width>325</width>
	<height>20</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="symbol" version="2.0.0">
		<name>Icon</name>
		<pv_name>$(device)$(temp)</pv_name>
		<symbols>
			<symbol>symbol/temperature 0.svg</symbol>
		</symbols>
		<width>40</width>
		<height>20</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open Display</description>
				<file>temperature_detail.bob</file>
				<target>tab</target>
			</action>
		</actions>
		<tooltip></tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<preserve_ratio>false</preserve_ratio>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>Readback</name>
		<pv_name>$(device)$(temp)</pv_name>
		<x>45</x>
		<width>146</width>
		<font>
			<font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Monitor: FG" red="96" green="255" blue="96"></color>
		</foreground_color>
		<background_color>
			<color name="Monitor: BG" red="64" green="64" blue="64"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="progressbar" version="2.0.0">
		<name>Progress Bar</name>
		<pv_name>$(device)$(temp)</pv_name>
		<x>190</x>
		<width>131</width>
		<height>21</height>
		<fill_color>
			<color red="56" green="255" blue="122"></color>
		</fill_color>
		<background_color>
			<color name="Monitor BG" red="105" green="105" blue="105"></color>
		</background_color>
		<actions></actions>
		<border_alarm_sensitive>true</border_alarm_sensitive>
	</widget>
</display>