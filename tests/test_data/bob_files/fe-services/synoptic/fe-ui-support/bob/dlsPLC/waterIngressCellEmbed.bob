<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Diamond Vacuum Overview</name>
	<x>752</x>
	<y>196</y>
	<width>1100</width>
	<height>40</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="led" version="2.0.0">
		<name>S-PIRG-01_LED</name>
		<pv_name>SR$(cell)C-VA-WINGR-$(id):S-PIRG-01:STATUS.B1</pv_name>
		<x>8</x>
		<y>11</y>
		<off_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<line_color>
			<color red="150" green="150" blue="150"></color>
		</line_color>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open Display</description>
				<file>waterIngressThresholdDetail.opi</file>
				<macros>
					<threshold>SR$(cell)C-VA-WINGR-$(id):S-PIRG-01:THRESHOLD</threshold>
					<interlock>S-PIRG-01</interlock>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<rules>
			<rule name="not_default_rule" prop_id="bulb_border_color" out_exp="false">
				<exp bool_exp="pv1==1 &amp;&amp; pv0==1">
					<value>&lt;color blue="0" green="241" name="Minor" red="255"/&gt;</value>
				</exp>
				<exp bool_exp="pv1==0 || pv0==0">
					<value>&lt;color blue="150" green="150" red="150"/&gt;</value>
				</exp>
				<pv_name trigger="false">SR$(cell)C-VA-WINGR-$(id):S-PIRG-01:THRESHOLD:NOT_DEFAULT.VAL</pv_name>
				<pv_name>sim://ramp(0,1,1,0.5)</pv_name>
			</rule>
			<rule name="interlock_visibility_rule" prop_id="visible" out_exp="false">
				<exp bool_exp="(pv0 &amp; 1)==1">
					<value>true</value>
				</exp>
				<exp bool_exp="(pv0 &amp; 1)!=1">
					<value>false</value>
				</exp>
				<pv_name>SR$(cell)C-VA-WINGR-$(id):INTERLOCK_MASK.VAL</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
