<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<width>325</width>
	<height>20</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="symbol" version="2.0.0">
		<name>Icon</name>
		<symbols>
			<symbol>symbol/flow 3.svg</symbol>
		</symbols>
		<width>40</width>
		<height>20</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open Display</description>
				<file>flow_detail.bob</file>
				<target>tab</target>
			</action>
		</actions>
		<tooltip></tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<preserve_ratio>false</preserve_ratio>
	</widget>
	<widget type="led" version="2.0.0">
		<name>LED</name>
		<pv_name>$(P)$(Q):LO</pv_name>
		<x>155</x>
		<off_color>
			<color name="Yellow LED: On" red="255" green="255" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: Off" red="0" green="128" blue="0"></color>
		</on_color>
		<foreground_color>
			<color red="192" green="192" blue="192"></color>
		</foreground_color>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="led" version="2.0.0">
		<name>LED_1</name>
		<pv_name>$(P)$(Q):LOLO</pv_name>
		<x>305</x>
		<off_color>
			<color name="Red LED: On" red="255" green="0" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: Off" red="0" green="128" blue="0"></color>
		</on_color>
		<foreground_color>
			<color red="192" green="192" blue="192"></color>
		</foreground_color>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="label" version="2.0.0">
		<name>Label</name>
		<text>Low Flow:</text>
		<x>40</x>
		<y>2</y>
		<width>111</width>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<horizontal_alignment>2</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>Label_1</name>
		<text>Low Low Flow:</text>
		<x>180</x>
		<width>120</width>
		<height>21</height>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<horizontal_alignment>2</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
</display>