	<widget type="byte_monitor" version="2.0.0">
		<name>auto(statusbits|Interlocks Current)_1</name>
		<pv_name>$(device):PLIM$(axisNo):RAWILK</pv_name>
		<x>14</x>
		<y>120</y>
		<width>21</width>
		<height>325</height>
		<numBits>16</numBits>
		<bitReverse>true</bitReverse>
		<horizontal>false</horizontal>
		<square>true</square>
		<off_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="led" version="2.0.0">
		<name>LED_2</name>
		<x>15</x>
		<y>65</y>
		<off_color>
			<color name="Red LED: On" red="255" green="0" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<line_color>
			<color red="150" green="150" blue="150"></color>
		</line_color>
		<actions></actions>
		<rules>
			<rule name="LEDState" prop_id="pv_value" out_exp="true">
				<exp bool_exp="pv0==65535 ">
					<expression>1</expression>
				</exp>
				<exp bool_exp="pv0!=65535">
					<expression>0</expression>
				</exp>
				<pv_name>$(device):PLIM$(axisNo):RAWILK</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
