		<show_legend>true</show_legend>
		<actions></actions>
		<rules>
			<rule name="gauge01Vis" prop_id="trace_0_visible" out_exp="false">
				<exp bool_exp="(pv0 &amp; 2) == 2">
					<value>true</value>
				</exp>
				<exp bool_exp="(pv0 &amp; 2) != 2">
					<value>false</value>
				</exp>
				<pv_name>$(dom)-VA-VFAST-01:GAUGE_MASK</pv_name>
			</rule>
			<rule name="gauge02Vis" prop_id="trace_1_visible" out_exp="false">
