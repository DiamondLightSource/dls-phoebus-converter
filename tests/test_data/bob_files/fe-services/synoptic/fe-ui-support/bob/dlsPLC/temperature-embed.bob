<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<x>1258</x>
	<y>966</y>
	<width>190</width>
	<height>20</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="action_button" version="2.0.0">
		<name>EDM related display</name>
		<width>191</width>
		<height>21</height>
		<line_width>0</line_width>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<transparent>true</transparent>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./temperature-tooltip.opi</file>
				<macros>
					<temp>$(temp)</temp>
					<label>$(label)</label>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text></text>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./temperature-config.bob</file>
				<macros>
					<temp>$(temp)</temp>
					<P>$(P)</P>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>$(label):</text>
		<width>81</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="10.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM Text Update</name>
		<pv_name>$(temp)</pv_name>
		<x>80</x>
		<width>91</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="BOLD" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<transparent>true</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>EDM Symbol</name>
		<file>symbols-traffic-light-symbol.bob</file>
		<x>170</x>
		<width>20</width>
		<height>20</height>
		<group_name>1</group_name>
		<transparent>true</transparent>
		<rules>
			<rule name="symbol_single_pv" prop_id="group_name" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>0</value>
				</exp>
				<exp bool_exp="pv0&gt;=-1.0&amp;&amp;pv0&lt;0.0">
					<value>0</value>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;1.0">
					<value>1</value>
				</exp>
				<exp bool_exp="pv0&gt;=1.0&amp;&amp;pv0&lt;2.0">
					<value>2</value>
				</exp>
				<exp bool_exp="pv0&gt;=2.0&amp;&amp;pv0&lt;3.0">
					<value>3</value>
				</exp>
				<exp bool_exp="true">
					<value>0</value>
				</exp>
				<pv_name>$(temp).SEVR</pv_name>
			</rule>
		</rules>
	</widget>
	<widget type="group" version="3.0.0">
		<name>0</name>
		<x>80</x>
		<width>111</width>
		<height>21</height>
		<style>3</style>
		<foreground_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</foreground_color>
		<line_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</line_color>
		<transparent>true</transparent>
		<rules>
			<rule name="visibleRule" prop_id="visible" out_exp="false">
				<exp bool_exp="pv0&gt;=1.0&amp;&amp; pv0&lt;2.0">
					<value>true</value>
				</exp>
				<exp bool_exp="true">
					<value>false</value>
				</exp>
				<pv_name>$(temp):DISABLED</pv_name>
			</rule>
		</rules>
		<widget type="label" version="2.0.0">
			<name>EDM Label</name>
			<text>Disabled</text>
			<width>110</width>
			<font>
				<font family="liberation sans" style="BOLD" size="14.0"></font>
			</font>
			<foreground_color>
				<color name="Text: FG" red="0" green="0" blue="0"></color>
			</foreground_color>
			<background_color>
				<color name="Canvas" red="200" green="200" blue="200"></color>
			</background_color>
			<transparent>false</transparent>
			<horizontal_alignment>1</horizontal_alignment>
			<vertical_alignment>1</vertical_alignment>
			<border_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</border_color>
		</widget>
	</widget>
</display>