<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<width>325</width>
	<height>70</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="label" version="2.0.0">
		<name>SPLabel</name>
		<text>Set Point</text>
		<x>45</x>
		<y>15</y>
		<width>76</width>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<horizontal_alignment>2</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="textentry" version="3.0.0">
		<name>auto(demand|setpoint)</name>
		<pv_name>$(P)$(Q):SP</pv_name>
		<x>125</x>
		<y>10</y>
		<height>25</height>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<show_units>false</show_units>
		<horizontal_alignment>1</horizontal_alignment>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>auto(readback|setpoint)</name>
		<pv_name>$(P)$(Q):SP:RBV</pv_name>
		<x>225</x>
		<y>10</y>
		<height>25</height>
		<font>
			<font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Monitor: FG" red="96" green="255" blue="96"></color>
		</foreground_color>
		<background_color>
			<color name="Monitor: BG" red="64" green="64" blue="64"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>Icon</name>
		<symbols>
			<symbol>symbol/PID.svg</symbol>
		</symbols>
		<x>5</x>
		<y>5</y>
		<width>32</width>
		<height>32</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open Display</description>
				<file>PIDControl_detail.bob</file>
				<target>tab</target>
			</action>
		</actions>
		<tooltip>Detail</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<preserve_ratio>false</preserve_ratio>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>auto(readback|output)</name>
		<pv_name>$(P)$(Q):OUTP</pv_name>
		<x>225</x>
		<y>40</y>
		<height>25</height>
		<font>
			<font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Monitor: FG" red="96" green="255" blue="96"></color>
		</foreground_color>
		<background_color>
			<color name="Monitor: BG" red="64" green="64" blue="64"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>SPLabel_1</name>
		<text>Output</text>
		<x>145</x>
		<y>42</y>
		<width>76</width>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<horizontal_alignment>2</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="led" version="2.0.0">
		<name>LoopStatus</name>
		<pv_name>$(P)$(Q):CTRL:STATUS</pv_name>
		<x>60</x>
		<y>42</y>
		<off_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</on_color>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<line_color>
			<color red="150" green="150" blue="150"></color>
		</line_color>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="label" version="2.0.0">
		<name>SPLabel_2</name>
		<text>Loop status</text>
		<x>85</x>
		<y>42</y>
		<width>76</width>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
</display>