<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<width>360</width>
	<height>57</height>
	<background_color>
		<color red="240" green="240" blue="240"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="group" version="3.0.0">
		<name>$(desc)</name>
		<width>360</width>
		<height>58</height>
		<widget type="embedded" version="2.0.0">
			<name>$(desc)_Content</name>
			<file>temperature_embed.opi</file>
			<width>330</width>
			<height>28</height>
			<resize>4</resize>
			<transparent>true</transparent>
			<actions></actions>
		</widget>
	</widget>
</display>