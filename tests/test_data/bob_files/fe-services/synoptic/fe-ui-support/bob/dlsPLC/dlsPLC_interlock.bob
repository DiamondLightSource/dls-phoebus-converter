<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Vacuum Valve - $(device)</name>
	<x>279</x>
	<y>167</y>
	<width>270</width>
	<height>535</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="embedded" version="2.0.0">
		<name>EDM linkingContainer</name>
		<x>10</x>
		<y>40</y>
		<width>250</width>
		<height>455</height>
		<resize>4</resize>
		<transparent>true</transparent>
		<scripts>
			<script file="EmbeddedJs">
				<text>importPackage(Packages.org.csstudio.opibuilder.scriptUtil);
var pv0 = PVUtil.getLong(pvs[0]);
if(pv0==0){
var macroInput = DataUtil.createMacrosInput(true);
macroInput.put("device", "$(device)");
widget.setPropertyValue("macros", macroInput);
widget.setPropertyValue("opi_file","./dlsPLC_interlock-embed.opi");
}</text>
				<pv_name>loc://dummy0&lt;VDouble&gt;(0)</pv_name>
			</script>
		</scripts>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>EXIT</text>
		<x>170</x>
		<y>505</y>
		<width>96</width>
		<height>26</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="18.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="192" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="group" version="3.0.0">
		<name>0</name>
		<width>271</width>
		<height>32</height>
		<style>3</style>
		<foreground_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</foreground_color>
		<line_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</line_color>
		<transparent>true</transparent>
		<widget type="group" version="3.0.0">
			<name>0</name>
			<y>2</y>
			<width>271</width>
			<height>26</height>
			<style>3</style>
			<foreground_color>
