<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Interlocks - $(P)</name>
	<x>1371</x>
	<y>487</y>
	<width>245</width>
	<height>375</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<y>5</y>
		<width>245</width>
		<height>370</height>
		<line_width>1</line_width>
		<line_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(desc)</text>
		<width>62</width>
		<height>13</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 50%" red="128" green="128" blue="128"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="byte_monitor" version="2.0.0">
		<name>EDM Byte</name>
		<pv_name>$(device):INIILK</pv_name>
		<x>24</x>
		<y>49</y>
		<width>22</width>
		<height>322</height>
		<numBits>16</numBits>
		<bitReverse>true</bitReverse>
		<horizontal>false</horizontal>
		<square>true</square>
		<off_color>
			<color name="Amber" red="255" green="192" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Yellow LED: Off" red="96" green="96" blue="0"></color>
		</on_color>
		<rules>
			<rule name="onColorAlarm" prop_id="on_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>$(device):INIILK</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM Text Update</name>
		<pv_name>$(device):ILK0</pv_name>
