<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<x>429</x>
	<y>551</y>
	<width>90</width>
	<height>20</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="action_button" version="2.0.0">
		<name>EDM related display</name>
		<width>91</width>
		<height>21</height>
		<line_width>0</line_width>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<transparent>true</transparent>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./flow-tooltip.opi</file>
				<macros>
					<flow>$(flow)</flow>
					<label>$(label)</label>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text></text>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>EDM Symbol</name>
		<file>symbols-traffic-light-symbol.bob</file>
		<x>70</x>
		<width>20</width>
		<height>20</height>
		<group_name>1</group_name>
		<transparent>true</transparent>
		<rules>
			<rule name="symbol_binary_truth_table" prop_id="group_name" out_exp="false">
				<exp bool_exp="((pv0==0?0:1)*1.0+(pv1==0?0:1)*2.0)&gt;=-1.0&amp;&amp;((pv0==0?0:1)*1.0+(pv1==0?0:1)*2.0)&lt;0.0">
					<value>0</value>
				</exp>
				<exp bool_exp="((pv0==0?0:1)*1.0+(pv1==0?0:1)*2.0)&gt;=3.0&amp;&amp;((pv0==0?0:1)*1.0+(pv1==0?0:1)*2.0)&lt;4.0">
					<value>1</value>
				</exp>
				<exp bool_exp="((pv0==0?0:1)*1.0+(pv1==0?0:1)*2.0)&gt;=2.0&amp;&amp;((pv0==0?0:1)*1.0+(pv1==0?0:1)*2.0)&lt;3.0">
					<value>2</value>
				</exp>
				<exp bool_exp="((pv0==0?0:1)*1.0+(pv1==0?0:1)*2.0)&gt;=0.0&amp;&amp;((pv0==0?0:1)*1.0+(pv1==0?0:1)*2.0)&lt;2.0">
					<value>3</value>
				</exp>
				<exp bool_exp="true">
					<value>0</value>
				</exp>
				<pv_name>$(flow):LO</pv_name>
				<pv_name>$(flow):LOLO</pv_name>
			</rule>
		</rules>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./flow-config.bob</file>
				<macros>
					<flow>$(flow)</flow>
					<label>$(label)</label>
					<P>$(P)</P>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>$(label):</text>
		<width>69</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
</display>