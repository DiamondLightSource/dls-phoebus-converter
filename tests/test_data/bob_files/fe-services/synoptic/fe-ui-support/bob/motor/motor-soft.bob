<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Motor - $(motor)</name>
	<x>645</x>
	<y>178</y>
	<width>411</width>
	<height>440</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="group" version="3.0.0">
		<name>0</name>
		<x>30</x>
		<width>361</width>
		<height>31</height>
		<style>3</style>
		<foreground_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</foreground_color>
		<line_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</line_color>
		<transparent>true</transparent>
		<widget type="rectangle" version="2.0.0">
			<name>EDM Rectangle</name>
			<width>356</width>
			<height>31</height>
			<line_width>1</line_width>
			<line_color>
				<color name="Grey 75%" red="192" green="192" blue="192"></color>
			</line_color>
			<background_color>
				<color name="Grey 75%" red="192" green="192" blue="192"></color>
			</background_color>
		</widget>
		<widget type="textupdate" version="2.0.0">
			<name>EDM Text Update</name>
			<pv_name>$(motor).DESC</pv_name>
			<y>3</y>
			<width>356</width>
			<height>25</height>
			<font>
				<font family="liberation sans" style="BOLD" size="14.0"></font>
			</font>
			<foreground_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</foreground_color>
			<background_color>
				<color name="CO title" red="169" green="210" blue="240"></color>
			</background_color>
			<horizontal_alignment>1</horizontal_alignment>
			<border_alarm_sensitive>false</border_alarm_sensitive>
			<border_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</border_color>
		</widget>
		<widget type="polyline" version="2.0.0">
			<name>EDM Line</name>
			<y>3</y>
			<width>356</width>
			<height>25</height>
			<points>
				<point x="0.0" y="24.0"></point>
				<point x="355.0" y="24.0"></point>
				<point x="355.0" y="0.0"></point>
			</points>
			<line_width>1</line_width>
			<line_color>
				<color name="Grey 40%" red="102" green="102" blue="102"></color>
			</line_color>
		</widget>
		<widget type="polyline" version="2.0.0">
			<name>EDM Line</name>
			<y>3</y>
			<width>356</width>
			<height>25</height>
			<points>
				<point x="0.0" y="24.0"></point>
				<point x="0.0" y="0.0"></point>
				<point x="355.0" y="0.0"></point>
			</points>
			<line_width>1</line_width>
			<line_color>
				<color name="Grey 90%" red="230" green="230" blue="230"></color>
			</line_color>
		</widget>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./motor-alarms.bob</file>
				<macros>
					<motor>$(motor)</motor>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>Alarms</text>
		<x>20</x>
		<y>400</y>
		<width>99</width>
		<height>29</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Dark Brown" red="128" green="96" blue="32"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>300</x>
		<y>400</y>
		<width>99</width>
		<height>29</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="192" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="scaledslider" version="2.0.0">
		<name>EDM Slider</name>
		<pv_name>$(motor)</pv_name>
		<x>2</x>
		<y>34</y>
		<width>390</width>
		<height>75</height>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</background_color>
		<font>
			<font family="liberation sans" style="REGULAR" size="10.0"></font>
		</font>
		<show_hihi>false</show_hihi>
		<show_high>false</show_high>
		<show_low>false</show_low>
		<show_lolo>false</show_lolo>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<maximum>0.0</maximum>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Message Button</name>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(motor).STOP</pv_name>
		<text>Stop</text>
		<x>100</x>
		<y>150</y>
		<width>199</width>
		<height>29</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Grey 75%" red="192" green="192" blue="192"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(motor).STOP</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="bool_button" version="2.0.0">
		<name>EDM Message Button</name>
		<pv_name>$(motor).JOGF</pv_name>
		<x>200</x>
		<y>180</y>
		<width>99</width>
		<height>29</height>
		<off_label>Forward</off_label>
		<off_color>
			<color name="Button_Background" red="210" green="210" blue="210"></color>
		</off_color>
		<on_label>Jogging</on_label>
		<on_color>
			<color red="168" green="168" blue="168"></color>
		</on_color>
		<show_led>false</show_led>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(motor).JOGF</pv_name>
				<value>1</value>
			</action>
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(motor).JOGF</pv_name>
				<value>0</value>
			</action>
		</actions>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Button: On" red="190" green="190" blue="190"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<mode>1</mode>
	</widget>
