<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Motor - $(motor)</name>
	<x>553</x>
	<y>111</y>
	<width>411</width>
	<height>503</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="group" version="3.0.0">
		<name>2</name>
		<x>30</x>
		<width>361</width>
		<height>31</height>
		<style>3</style>
		<foreground_color>
			<color red="0" green="128" blue="255"></color>
		</foreground_color>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<transparent>true</transparent>
		<actions></actions>
		<widget type="rectangle" version="2.0.0">
			<name>EDM Rectangle</name>
			<macros>
				<pv_name></pv_name>
			</macros>
			<width>356</width>
			<height>31</height>
			<line_width>0</line_width>
			<line_color>
				<color red="0" green="128" blue="255"></color>
			</line_color>
			<background_color>
				<color name="Grey 75%" red="192" green="192" blue="192"></color>
			</background_color>
			<actions></actions>
			<tooltip>$(pv_name)
$(pv_value)</tooltip>
		</widget>
		<widget type="textupdate" version="2.0.0">
			<name>EDM Text Update</name>
			<pv_name>$(motor).DESC</pv_name>
			<y>3</y>
			<width>356</width>
			<height>25</height>
			<font>
				<font family="liberation sans" style="BOLD" size="14.0"></font>
			</font>
			<foreground_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</foreground_color>
			<background_color>
				<color name="CO title" red="169" green="210" blue="240"></color>
			</background_color>
			<horizontal_alignment>1</horizontal_alignment>
			<vertical_alignment>1</vertical_alignment>
			<wrap_words>false</wrap_words>
			<actions></actions>
			<border_alarm_sensitive>false</border_alarm_sensitive>
			<border_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</border_color>
		</widget>
		<widget type="polyline" version="2.0.0">
			<name>EDM Line</name>
			<macros>
				<pv_name></pv_name>
			</macros>
			<y>3</y>
			<width>356</width>
			<height>25</height>
			<points>
				<point x="0.0" y="24.0"></point>
				<point x="355.0" y="24.0"></point>
				<point x="355.0" y="0.0"></point>
			</points>
			<line_width>1</line_width>
			<line_color>
				<color name="Grey 40%" red="102" green="102" blue="102"></color>
			</line_color>
			<actions></actions>
			<tooltip>$(pv_name)
$(pv_value)</tooltip>
		</widget>
		<widget type="polyline" version="2.0.0">
			<name>EDM Line</name>
			<macros>
				<pv_name></pv_name>
			</macros>
			<y>3</y>
			<width>356</width>
			<height>25</height>
			<points>
				<point x="0.0" y="24.0"></point>
				<point x="0.0" y="0.0"></point>
				<point x="355.0" y="0.0"></point>
			</points>
			<line_width>1</line_width>
			<line_color>
				<color name="Grey 90%" red="230" green="230" blue="230"></color>
			</line_color>
			<actions></actions>
			<tooltip>$(pv_name)
$(pv_value)</tooltip>
		</widget>
	</widget>
