	<widget type="scaledslider" version="2.0.0">
		<name>EDM Slider</name>
		<pv_name>$(motor)</pv_name>
		<x>2</x>
		<y>34</y>
		<width>390</width>
		<height>75</height>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</background_color>
		<major_tick_step_hint>50</major_tick_step_hint>
		<scale_format></scale_format>
		<show_hihi>false</show_hihi>
		<show_high>false</show_high>
		<show_low>false</show_low>
		<show_lolo>false</show_lolo>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<maximum>0.0</maximum>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Message Button</name>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(motor).STOP</pv_name>
		<text>Stop</text>
		<x>105</x>
		<y>151</y>
		<width>199</width>
		<height>29</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Grey 75%" red="192" green="192" blue="192"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(motor).STOP</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="bool_button" version="2.0.0">
		<name>EDM Message Button</name>
		<pv_name>$(motor).JOGF</pv_name>
		<bit>-1</bit>
		<x>205</x>
		<y>211</y>
		<width>99</width>
		<height>29</height>
		<off_label>Forward</off_label>
		<off_color>
			<color red="240" green="240" blue="240"></color>
		</off_color>
		<on_label>Jogging</on_label>
		<on_color>
			<color red="192" green="192" blue="192"></color>
		</on_color>
		<show_led>false</show_led>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(motor).JOGF</pv_name>
				<value>1</value>
			</action>
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(motor).JOGF</pv_name>
				<value>0</value>
			</action>
		</actions>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Button: On" red="190" green="190" blue="190"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<mode>1</mode>
		<confirm_message>Are you sure you want to do this?</confirm_message>
	</widget>
