<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<x>384</x>
	<y>971</y>
	<width>229</width>
	<height>21</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="action_button" version="2.0.0">
		<name>EDM related display</name>
		<width>231</width>
		<height>21</height>
		<line_width>0</line_width>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<transparent>true</transparent>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./motor-embed-homed-tooltip.opi</file>
				<macros>
					<label>$(label)</label>
					<motor>$(motor)</motor>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text></text>
	</widget>
	<widget type="byte_monitor" version="2.0.0">
		<name>EDM Byte</name>
		<pv_name>$(motor).MSTA</pv_name>
		<x>205</x>
		<width>21</width>
		<height>21</height>
		<startBit>14</startBit>
		<numBits>1</numBits>
		<horizontal>false</horizontal>
		<square>true</square>
		<off_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<rules>
			<rule name="onColorAlarm" prop_id="on_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>$(motor).MSTA</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./motor.bob</file>
				<macros>
					<motor>$(motor)</motor>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>$(label)</text>
		<width>109</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="BOLD" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Related Display: FG" red="128" green="64" blue="32"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM Text Update</name>
		<pv_name>$(motor).RBV</pv_name>
		<x>110</x>
		<width>94</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Monitor: FG" red="96" green="255" blue="96"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 25%" red="64" green="64" blue="64"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color name="Mid Green" red="0" green="192" blue="0"></color>
		</border_color>
	</widget>
</display>