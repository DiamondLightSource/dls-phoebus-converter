	<widget type="action_button" version="3.0.0">
		<name>EDM Message Button</name>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(motor).STOP</pv_name>
		<text>STOP</text>
		<x>233</x>
		<y>183</y>
		<width>53</width>
		<height>23</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Red" red="255" green="0" blue="0"></color>
		</foreground_color>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Grey 75%" red="192" green="192" blue="192"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(motor).STOP</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>DLS symbol</name>
		<pv_name>$(motor).SEVR</pv_name>
		<symbols>
			<symbol>../motor/symbols-traffic-light-symbol-21.png</symbol>
		</symbols>
		<x>108</x>
		<y>156</y>
		<width>20</width>
		<height>20</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<rules>
			<rule name="symbol_single_pv" prop_id="image_index" out_exp="true">
				<exp bool_exp="pvSev0==3">
					<expression>0</expression>
				</exp>
				<exp bool_exp="pv0&gt;=3.0&amp;&amp;pv0&lt;4.0">
					<expression>0</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;0.0">
					<expression>1</expression>
				</exp>
				<exp bool_exp="pv0&gt;=1.0&amp;&amp;pv0&lt;2.0">
					<expression>2</expression>
				</exp>
				<exp bool_exp="pv0&gt;=2.0&amp;&amp;pv0&lt;3.0">
					<expression>3</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;1.0">
					<expression>4</expression>
				</exp>
				<exp bool_exp="true">
					<expression>0</expression>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>DLS symbol</name>
		<pv_name>$(motor).DMOV</pv_name>
		<symbols>
			<symbol>../motor/symbols-traffic-light-symbol-21.png</symbol>
		</symbols>
		<x>262</x>
		<y>156</y>
		<width>20</width>
		<height>20</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<rules>
			<rule name="symbol_single_pv" prop_id="image_index" out_exp="true">
				<exp bool_exp="pvSev0==3">
					<expression>0</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;0.0">
					<expression>3</expression>
				</exp>
				<exp bool_exp="pv0&gt;=1.0&amp;&amp;pv0&lt;2.0">
					<expression>4</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;1.0">
					<expression>5</expression>
				</exp>
				<exp bool_exp="true">
					<expression>0</expression>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
