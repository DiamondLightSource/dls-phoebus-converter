	<widget type="group" version="3.0.0">
		<name>0</name>
		<x>221</x>
		<y>106</y>
		<width>19</width>
		<height>12</height>
		<style>3</style>
		<foreground_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</foreground_color>
		<line_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</line_color>
		<transparent>true</transparent>
		<rules>
			<rule name="visibleRule" prop_id="visible" out_exp="false">
				<exp bool_exp="pv0&gt;=0.0&amp;&amp; pv0&lt;1.0">
					<value>true</value>
				</exp>
				<exp bool_exp="true">
					<value>false</value>
				</exp>
				<pv_name>$(motor):KILL</pv_name>
			</rule>
		</rules>
		<widget type="action_button" version="3.0.0">
			<name>EDM Message Button</name>
			<actions execute_as_one="true">
				<action type="write_pv">
					<description>Write PV</description>
					<pv_name>$(pv_name)</pv_name>
					<value>1</value>
				</action>
			</actions>
			<pv_name>$(motor):KILL.PROC</pv_name>
			<text>Kill</text>
			<width>19</width>
			<height>14</height>
			<font>
				<font family="liberation sans" style="REGULAR" size="8.0"></font>
			</font>
			<foreground_color>
				<color name="Mid Red" red="192" green="0" blue="0"></color>
			</foreground_color>
			<rules>
				<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
					<exp bool_exp="pv0 == 1">
						<value>
							<color name="Grey 75%" red="192" green="192" blue="192"></color>
						</value>
					</exp>
					<exp bool_exp="true">
						<value>
							<color name="Controller: BG" red="205" green="205" blue="205"></color>
						</value>
					</exp>
					<pv_name>$(motor):KILL.PROC</pv_name>
				</rule>
			</rules>
			<border_alarm_sensitive>false</border_alarm_sensitive>
		</widget>
	</widget>
