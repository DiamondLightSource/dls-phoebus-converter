<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Motor Calibration - $(motor)</name>
	<x>260</x>
	<y>398</y>
	<width>381</width>
	<height>232</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<width>376</width>
		<height>53</height>
		<line_width>1</line_width>
		<line_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(motor)
Calibration-Related Fields</text>
		<width>381</width>
		<height>54</height>
		<font>
			<font family="liberation sans" style="BOLD" size="18.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="combo" version="2.0.0">
		<name>EDM menu button</name>
		<pv_name>$(motor).SET</pv_name>
		<x>240</x>
		<y>165</y>
		<width>131</width>
		<height>29</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>.DIR - Direction</text>
		<x>10</x>
		<y>63</y>
		<width>115</width>
		<height>19</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>.OFF - User Offset</text>
		<x>10</x>
		<y>102</y>
		<width>135</width>
		<height>19</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="textentry" version="3.0.0">
		<name>EDM Text Entry</name>
		<pv_name>$(motor).OFF</pv_name>
		<x>240</x>
		<y>90</y>
		<width>131</width>
		<height>41</height>
		<font>
			<font family="liberation sans" style="BOLD" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color name="Blue" red="0" green="0" blue="255"></color>
		</border_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>.FOFF - Offset/Freeze Switch</text>
		<x>10</x>
		<y>140</y>
		<width>215</width>
		<height>19</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="combo" version="2.0.0">
		<name>EDM menu button</name>
		<pv_name>$(motor).FOFF</pv_name>
		<x>240</x>
		<y>134</y>
		<width>131</width>
		<height>29</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>.SET - Set/Use Switch</text>
		<x>10</x>
		<y>170</y>
		<width>162</width>
		<height>19</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="combo" version="2.0.0">
		<name>EDM menu button</name>
		<pv_name>$(motor).DIR</pv_name>
		<x>240</x>
		<y>58</y>
		<width>131</width>
		<height>29</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>240</x>
		<y>196</y>
		<width>131</width>
		<height>29</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="192" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
</display>