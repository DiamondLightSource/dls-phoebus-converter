<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<width>325</width>
	<height>20</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="led" version="2.0.0">
		<name>Homed</name>
		<pv_name>$(P)$(M).MSTA</pv_name>
		<bit>14</bit>
		<x>305</x>
		<off_color>
			<color red="0" green="100" blue="0"></color>
		</off_color>
		<foreground_color>
			<color red="192" green="192" blue="192"></color>
		</foreground_color>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>Readback</name>
		<pv_name>$(P)$(M).RBV</pv_name>
		<x>40</x>
		<width>206</width>
		<font>
			<font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Monitor: FG" red="96" green="255" blue="96"></color>
		</foreground_color>
		<background_color>
			<color name="Monitor: BG" red="64" green="64" blue="64"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>Symbol</name>
		<pv_name>$(P)$(M).MOVN</pv_name>
		<symbols>
			<symbol>symbol/motor 0.gif</symbol>
		</symbols>
		<width>40</width>
		<height>20</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open detail screen</description>
				<file>motor_detail.bob</file>
				<target>tab</target>
			</action>
		</actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<preserve_ratio>false</preserve_ratio>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>Symbol_1</name>
		<pv_name>$(P):HM:HOMING</pv_name>
		<symbols>
			<symbol>../pmacUtilApp_opi/symbol/motorhome 0.gif</symbol>
		</symbols>
		<x>255</x>
		<width>40</width>
		<height>20</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open detail screen</description>
				<file>../pmacUtilApp_opi/motorhome_detail.bob</file>
				<target>tab</target>
			</action>
		</actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<preserve_ratio>false</preserve_ratio>
	</widget>
</display>