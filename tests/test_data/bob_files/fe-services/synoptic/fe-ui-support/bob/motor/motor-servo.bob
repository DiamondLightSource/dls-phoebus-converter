<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Motor Record - Servo Fields - $(motor)</name>
	<x>299</x>
	<y>193</y>
	<width>420</width>
	<height>300</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>6</grid_step_x>
	<grid_step_y>6</grid_step_y>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<macros>
			<pv_name></pv_name>
		</macros>
		<width>421</width>
		<height>53</height>
		<line_width>0</line_width>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
		<actions></actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(motor)
Servo Fields</text>
		<width>420</width>
		<height>54</height>
		<font>
			<font family="liberation sans" style="BOLD" size="18.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>.CNEN - Enable Control</text>
		<x>10</x>
		<y>64</y>
		<width>171</width>
		<height>19</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="combo" version="2.0.0">
		<name>EDM menu button</name>
		<pv_name>$(motor).CNEN</pv_name>
		<x>200</x>
		<y>60</y>
		<width>121</width>
		<height>26</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="scaledslider" version="2.0.0">
		<name>EDM Motif Slider</name>
		<pv_name>$(motor).ICOF</pv_name>
		<x>10</x>
		<y>131</y>
		<height>85</height>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</background_color>
		<major_tick_step_hint>50</major_tick_step_hint>
		<scale_format></scale_format>
		<show_hihi>false</show_hihi>
		<show_high>false</show_high>
		<show_low>false</show_low>
		<show_lolo>false</show_lolo>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<maximum>1.0</maximum>
		<limits_from_pv>false</limits_from_pv>
	</widget>
	<widget type="scaledslider" version="2.0.0">
		<name>EDM Motif Slider</name>
		<pv_name>$(motor).DCOF</pv_name>
		<x>10</x>
		<y>204</y>
		<height>82</height>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</background_color>
		<major_tick_step_hint>50</major_tick_step_hint>
		<scale_format></scale_format>
		<show_hihi>false</show_hihi>
		<show_high>false</show_high>
		<show_low>false</show_low>
		<show_lolo>false</show_lolo>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<maximum>1.0</maximum>
		<limits_from_pv>false</limits_from_pv>
	</widget>
	<widget type="scaledslider" version="2.0.0">
		<name>EDM Motif Slider</name>
		<pv_name>$(motor).PCOF</pv_name>
		<x>10</x>
		<y>60</y>
		<height>86</height>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</background_color>
		<major_tick_step_hint>50</major_tick_step_hint>
		<scale_format></scale_format>
		<show_hihi>false</show_hihi>
		<show_high>false</show_high>
		<show_low>false</show_low>
		<show_lolo>false</show_lolo>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<maximum>1.0</maximum>
		<limits_from_pv>false</limits_from_pv>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>330</x>
		<y>58</y>
		<width>81</width>
		<height>29</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="196" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
</display>