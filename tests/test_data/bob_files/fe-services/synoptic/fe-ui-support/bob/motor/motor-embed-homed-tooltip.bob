<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<x>613</x>
	<y>453</y>
	<width>375</width>
	<height>220</height>
	<background_color>
		<color name="TI title" red="210" green="201" blue="172"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="polyline" version="2.0.0">
		<name>EDM Line</name>
		<width>377</width>
		<height>222</height>
		<points>
			<point x="1.0" y="221.0"></point>
			<point x="376.0" y="221.0"></point>
			<point x="376.0" y="1.0"></point>
		</points>
		<line_width>2</line_width>
		<line_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</line_color>
	</widget>
	<widget type="polyline" version="2.0.0">
		<name>EDM Line</name>
		<width>377</width>
		<height>222</height>
		<points>
			<point x="1.0" y="221.0"></point>
			<point x="1.0" y="1.0"></point>
			<point x="376.0" y="1.0"></point>
		</points>
		<line_width>2</line_width>
		<line_color>
			<color name="Grey 90%" red="230" green="230" blue="230"></color>
		</line_color>
	</widget>
	<widget type="byte_monitor" version="2.0.0">
		<name>EDM Byte</name>
		<pv_name>$(motor).MSTA</pv_name>
		<x>279</x>
		<y>99</y>
		<width>21</width>
		<height>21</height>
		<startBit>14</startBit>
		<numBits>1</numBits>
		<horizontal>false</horizontal>
		<square>true</square>
		<off_color>
			<color name="Green LED: Off" red="0" green="96" blue="0"></color>
		</off_color>
		<on_color>
			<color name="Green LED: On" red="0" green="255" blue="0"></color>
		</on_color>
		<rules>
			<rule name="onColorAlarm" prop_id="on_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>$(motor).MSTA</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM Text Update</name>
		<pv_name>$(motor).RBV</pv_name>
		<x>185</x>
		<y>100</y>
		<width>94</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Monitor: FG" red="96" green="255" blue="96"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 25%" red="64" green="64" blue="64"></color>
		</background_color>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color name="Mid Green" red="0" green="192" blue="0"></color>
		</border_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
