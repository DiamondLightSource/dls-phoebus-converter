<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Motor box small</name>
	<x>554</x>
	<y>676</y>
	<width>190</width>
	<height>110</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="action_button" version="2.0.0">
		<name>EDM related display</name>
		<width>190</width>
		<height>110</height>
		<line_width>0</line_width>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<transparent>true</transparent>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>./motor-embed-small-tooltip.opi</file>
				<macros>
					<box-label>$(box-label)</box-label>
					<motor>$(motor)</motor>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text></text>
	</widget>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<y>5</y>
		<width>190</width>
		<height>105</height>
		<line_width>1</line_width>
		<line_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Message Button</name>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(motor).STOP</pv_name>
		<text>STOP</text>
		<x>133</x>
		<y>83</y>
		<width>53</width>
		<height>23</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Red" red="255" green="0" blue="0"></color>
		</foreground_color>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Grey 75%" red="192" green="192" blue="192"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(motor).STOP</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>DLS symbol</name>
		<pv_name>$(motor).SEVR</pv_name>
		<symbols>
			<symbol>../motor/symbols-traffic-light-symbol-21.png</symbol>
		</symbols>
		<x>8</x>
		<y>56</y>
		<width>20</width>
		<height>20</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<rules>
			<rule name="symbol_single_pv" prop_id="image_index" out_exp="true">
				<exp bool_exp="pvSev0==3">
					<expression>0</expression>
				</exp>
				<exp bool_exp="pv0&gt;=3.0&amp;&amp;pv0&lt;4.0">
					<expression>0</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;0.0">
					<expression>1</expression>
				</exp>
				<exp bool_exp="pv0&gt;=1.0&amp;&amp;pv0&lt;2.0">
					<expression>2</expression>
				</exp>
				<exp bool_exp="pv0&gt;=2.0&amp;&amp;pv0&lt;3.0">
					<expression>3</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;1.0">
					<expression>4</expression>
				</exp>
				<exp bool_exp="true">
					<expression>0</expression>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>DLS symbol</name>
		<pv_name>$(motor).DMOV</pv_name>
		<symbols>
			<symbol>../motor/symbols-traffic-light-symbol-21.png</symbol>
		</symbols>
		<x>162</x>
		<y>56</y>
		<width>20</width>
		<height>20</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<rules>
			<rule name="symbol_single_pv" prop_id="image_index" out_exp="true">
				<exp bool_exp="pvSev0==3">
					<expression>0</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;0.0">
					<expression>3</expression>
				</exp>
				<exp bool_exp="pv0&gt;=1.0&amp;&amp;pv0&lt;2.0">
					<expression>4</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;1.0">
					<expression>5</expression>
				</exp>
				<exp bool_exp="true">
					<expression>0</expression>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>$(filename).bob</file>
				<macros>
					<motor>$(motor)</motor>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>More</text>
		<x>5</x>
		<y>83</y>
		<width>53</width>
		<height>23</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Related Display: FG" red="128" green="64" blue="32"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(box-label)</text>
		<width>79</width>
		<height>13</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 50%" red="128" green="128" blue="128"></color>
		</background_color>
		<transparent>false</transparent>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="textentry" version="3.0.0">
		<name>EDM TextInput</name>
		<pv_name>$(motor).TWV</pv_name>
		<x>65</x>
		<y>85</y>
		<width>60</width>
		<height>16</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<show_units>false</show_units>
		<horizontal_alignment>1</horizontal_alignment>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Message Button</name>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(motor).TWR</pv_name>
		<text>-</text>
		<x>5</x>
		<y>21</y>
		<width>44</width>
		<font>
			<font family="liberation sans" style="BOLD" size="24.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Grey 75%" red="192" green="192" blue="192"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(motor).TWR</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="textentry" version="3.0.0">
		<name>EDM Text Entry</name>
		<pv_name>$(motor)</pv_name>
		<x>54</x>
		<y>20</y>
		<width>81</width>
		<height>31</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color red="0" green="0" blue="0" alpha="0"></color>
		</background_color>
		<format>1</format>
		<precision>4</precision>
		<show_units>false</show_units>
		<horizontal_alignment>1</horizontal_alignment>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color name="Blue" red="0" green="0" blue="255"></color>
		</border_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Message Button</name>
		<actions execute_as_one="true">
			<action type="write_pv">
