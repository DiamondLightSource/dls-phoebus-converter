				<color name="Black" red="0" green="0" blue="0"></color>
			</foreground_color>
			<background_color>
				<color name="CO title" red="169" green="210" blue="240"></color>
			</background_color>
			<horizontal_alignment>1</horizontal_alignment>
			<border_alarm_sensitive>false</border_alarm_sensitive>
			<border_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</border_color>
		</widget>
		<widget type="polyline" version="2.0.0">
			<name>EDM Line</name>
			<y>3</y>
			<width>356</width>
			<height>25</height>
			<points>
				<point x="0.0" y="24.0"></point>
				<point x="355.0" y="24.0"></point>
				<point x="355.0" y="0.0"></point>
			</points>
			<line_width>1</line_width>
			<line_color>
				<color name="Grey 40%" red="102" green="102" blue="102"></color>
			</line_color>
		</widget>
		<widget type="polyline" version="2.0.0">
			<name>EDM Line</name>
			<y>3</y>
			<width>356</width>
			<height>25</height>
			<points>
				<point x="0.0" y="24.0"></point>
				<point x="0.0" y="0.0"></point>
				<point x="355.0" y="0.0"></point>
