			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(pv_name)</pv_name>
				<value>1</value>
			</action>
		</actions>
		<pv_name>$(motor):NOM.PROC</pv_name>
		<text>Nominal Position</text>
		<x>105</x>
		<y>181</y>
		<width>199</width>
		<height>29</height>
