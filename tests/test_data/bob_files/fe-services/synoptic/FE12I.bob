<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>$(dom)</name>
	<x>543</x>
	<y>581</y>
	<width>1080</width>
	<height>700</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<macros>
			<pv_name></pv_name>
		</macros>
		<x>48</x>
		<y>328</y>
		<width>5</width>
		<height>33</height>
		<line_width>0</line_width>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color name="Mid Green" red="0" green="196" blue="0"></color>
		</background_color>
		<actions></actions>
		<rules>
			<rule name="lineColorAlarmRule" prop_id="line_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>$(dom)-VA-SPACE-01:STA</pv_name>
			</rule>
			<rule name="backColorAlarmRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pvSev0==3">
					<value>
						<color name="Invalid" red="255" green="255" blue="255"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==2">
					<value>
						<color name="Major" red="255" green="0" blue="0"></color>
					</value>
				</exp>
				<exp bool_exp="pvSev0==1">
					<value>
						<color name="Minor" red="255" green="241" blue="0"></color>
					</value>
				</exp>
				<pv_name>$(dom)-VA-SPACE-01:STA</pv_name>
			</rule>
		</rules>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>FE$(cell)$(type) Control</text>
		<width>1080</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="VA title" red="202" green="223" blue="159"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>DLS symbol</name>
		<pv_name>SR$(cell)A-VA-VALVE-$(srvalve):STA</pv_name>
		<symbols>
			<symbol>fe-ui-support/symbols/vacuumValve-symbol-34.png</symbol>
		</symbols>
		<x>16</x>
		<y>320</y>
		<width>24</width>
		<height>24</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>fe-ui-support/bob/dlsPLC/vacuumValve.bob</file>
				<macros>
					<device>SR$(cell)A-VA-VALVE-$(srvalve)</device>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<rules>
			<rule name="symbol_single_pv" prop_id="image_index" out_exp="true">
				<exp bool_exp="pvSev0==3">
					<expression>0</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;0.0">
					<expression>0</expression>
				</exp>
				<exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;1.0">
					<expression>1</expression>
				</exp>
				<exp bool_exp="pv0&gt;=1.0&amp;&amp;pv0&lt;2.0">
					<expression>2</expression>
				</exp>
				<exp bool_exp="pv0&gt;=2.0&amp;&amp;pv0&lt;3.0">
					<expression>3</expression>
				</exp>
				<exp bool_exp="pv0&gt;=3.0&amp;&amp;pv0&lt;4.0">
					<expression>4</expression>
				</exp>
				<exp bool_exp="pv0&gt;=4.0&amp;&amp;pv0&lt;5.0">
					<expression>5</expression>
				</exp>
				<exp bool_exp="true">
					<expression>0</expression>
				</exp>
				<pv_name>$(pv_name)</pv_name>
			</rule>
		</rules>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
