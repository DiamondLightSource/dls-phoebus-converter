<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>$(device)</name>
	<x>558</x>
	<y>230</y>
	<width>264</width>
	<height>180</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<grid_step_x>4</grid_step_x>
	<grid_step_y>4</grid_step_y>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<x>8</x>
		<y>40</y>
		<width>249</width>
		<height>101</height>
		<line_width>1</line_width>
		<line_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(device)</text>
		<width>264</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="RS title" red="225" green="193" blue="144"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>200</x>
		<y>148</y>
		<width>57</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="192" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>WARNING</text>
		<x>16</x>
		<y>40</y>
		<width>232</width>
		<height>24</height>
		<font>
			<font family="liberation sans" style="BOLD" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Red" red="255" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="Red" red="255" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Turning off this gauge when the
beamline is open to the
Front End will trip the machine!</text>
		<x>16</x>
		<y>60</y>
		<width>232</width>
		<height>64</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="combo" version="2.0.0">
		<name>EDM menu button</name>
		<pv_name>$(device):CCHV</pv_name>
		<x>88</x>
		<y>148</y>
		<width>71</width>
		<height>26</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<rules>
			<rule name="visibleRule" prop_id="visible" out_exp="false">
				<exp bool_exp="pv0&gt;=0.0&amp;&amp; pv0&lt;1.0">
					<value>true</value>
				</exp>
				<exp bool_exp="true">
					<value>false</value>
				</exp>
				<pv_name>$(device):SWITCHING</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM Text Update</name>
		<pv_name>$(device):SWITCHING</pv_name>
		<x>68</x>
		<y>152</y>
		<width>91</width>
		<height>18</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Mid Green" red="0" green="192" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Monitor: BG" red="64" green="64" blue="64"></color>
		</background_color>
		<transparent>true</transparent>
		<horizontal_alignment>2</horizontal_alignment>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color name="Mid Green" red="0" green="192" blue="0"></color>
		</border_color>
	</widget>
</display>