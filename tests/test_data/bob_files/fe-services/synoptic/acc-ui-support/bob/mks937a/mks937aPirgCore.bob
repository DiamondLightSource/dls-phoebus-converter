	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>168</x>
		<y>308</y>
		<width>65</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="196" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM shell command</name>
		<actions>
			<action type="command">
				<description>Launch databrowser</description>
				<script file="EmbeddedPy">
					<text>from org.csstudio.opibuilder.scriptUtil import ScriptUtil

command_id="org.csstudio.trends.databrowser2.newWindow"
ScriptUtil.executeEclipseCommand(command_id, ['pvnames', '$(device):PLOG'])</text>
				</script>
				<command>$(phoebus.install)/../phoebus.sh -resource "pv://?$(device):PLOG&amp;app=databrowser</command>
			</action>
		</actions>
		<text>Graph</text>
		<x>8</x>
		<y>308</y>
		<width>57</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Related Display: FG" red="128" green="64" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="meter" version="3.0.0">
		<name>EDM meter Hulei</name>
		<pv_name>$(device):P</pv_name>
		<x>16</x>
		<y>64</y>
		<width>208</width>
		<height>109</height>
		<foreground_color>
			<color name="Mid Green" red="0" green="196" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 25%" red="64" green="64" blue="64"></color>
		</background_color>
		<show_value>false</show_value>
		<show_limits>false</show_limits>
		<log_scale>true</log_scale>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<minimum>0.001</minimum>
		<maximum>1000.0</maximum>
		<needle_color>
			<color name="Mid Green" red="0" green="196" blue="0"></color>
		</needle_color>
	</widget>
