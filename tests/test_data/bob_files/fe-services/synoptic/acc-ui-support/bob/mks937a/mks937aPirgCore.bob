<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>MKS 937A Pirani Gauge - $(device)</name>
	<x>31</x>
	<y>320</y>
	<width>240</width>
	<height>334</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(device)</text>
		<width>240</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="16.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="VA title" red="202" green="223" blue="159"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<macros>
			<pv_name></pv_name>
		</macros>
		<x>8</x>
		<y>48</y>
		<width>225</width>
		<height>253</height>
		<line_width>0</line_width>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
		<actions></actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Details</text>
		<x>8</x>
		<y>40</y>
		<width>48</width>
		<height>16</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="12.0"></font>
		</font>
		<foreground_color>
			<color name="Grey 90%" red="230" green="230" blue="230"></color>
		</foreground_color>
		<background_color>
			<color name="Grey 50%" red="128" green="128" blue="128"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Grey 90%" red="230" green="230" blue="230"></color>
		</border_color>
	</widget>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<macros>
			<pv_name></pv_name>
		</macros>
		<x>8</x>
		<y>40</y>
		<width>49</width>
		<height>17</height>
		<line_width>0</line_width>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</background_color>
		<transparent>true</transparent>
		<actions></actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Pressure (mbar)</text>
		<x>16</x>
		<y>188</y>
		<width>104</width>
		<height>17</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>EDM Text Update</name>
		<pv_name>$(device):P</pv_name>
		<x>151</x>
		<y>183</y>
		<width>72</width>
		<height>24</height>
		<font>
			<font family="liberation sans" style="BOLD" size="14.0"></font>
		</font>
