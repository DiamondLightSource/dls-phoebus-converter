	<widget type="group" version="3.0.0">
		<name>0</name>
		<x>136</x>
		<y>312</y>
		<width>57</width>
		<height>25</height>
		<style>3</style>
		<foreground_color>
			<color red="0" green="128" blue="255"></color>
		</foreground_color>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<transparent>true</transparent>
		<actions></actions>
		<rules>
			<rule name="visibleRule" prop_id="visible" out_exp="false">
				<exp bool_exp="pv0&gt;=1.0&amp;&amp; pv0&lt;2.0">
					<value>false</value>
				</exp>
				<exp bool_exp="true">
					<value>true</value>
				</exp>
				<pv_name>=(`loc://$(DID)noImg&lt;VDouble&gt;($(NOIMG))`)</pv_name>
			</rule>
		</rules>
