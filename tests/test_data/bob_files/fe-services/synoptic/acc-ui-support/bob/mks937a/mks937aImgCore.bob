			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="VA title" red="202" green="223" blue="159"></color>
		</background_color>
		<transparent>false</transparent>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions><action type="close_display" description="Close display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>162</x>
		<y>400</y>
		<width>71</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="196" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM shell command</name>
		<actions><action type="command">
				<description>Launch databrowser</description>
				<command>$(phoebus.install)/../phoebus.sh -resource "pv://?$(device):PLOG&amp;app=databrowser</command>
			</action>
		</actions>
		<text>Graph</text>
