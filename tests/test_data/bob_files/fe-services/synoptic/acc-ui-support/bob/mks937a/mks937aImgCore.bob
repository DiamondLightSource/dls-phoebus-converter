<?xml version='1.0' encoding='UTF-8'?>
<display version="2.0.0">
	<name>MKS 937A Inverted Magenetron Gauge - $(device)</name>
	<x>64</x>
	<y>703</y>
	<width>238</width>
	<height>428</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>4</grid_step_x>
	<grid_step_y>4</grid_step_y>
	<widget type="rectangle" version="2.0.0">
		<name>EDM Rectangle</name>
		<macros>
			<pv_name/>
		</macros>
		<x>8</x>
		<y>344</y>
		<width>225</width>
		<height>49</height>
		<line_width>0</line_width>
		<line_color>
			<color red="0" green="128" blue="255"></color>
		</line_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
		<actions></actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>$(device)</text>
		<width>240</width>
		<height>32</height>
		<font>
			<font family="liberation sans" style="BOLD" size="16.0"></font>
		</font>
