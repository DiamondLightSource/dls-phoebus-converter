	<widget type="action_button" version="3.0.0">
		<name>EDM Message Button</name>
		<actions execute_as_one="true">
			<action type="write_pv">
				<description>Write PV</description>
				<pv_name>$(pv_name)</pv_name>
				<value>Clear</value>
			</action>
		</actions>
		<pv_name>$(device):CLEAR</pv_name>
		<text>Clear</text>
		<x>400</x>
		<y>150</y>
		<width>119</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color red="240" green="240" blue="240"></color>
		</background_color>
		<rules>
			<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
				<exp bool_exp="pv0 == 1">
					<value>
						<color name="Grey 75%" red="192" green="192" blue="192"></color>
					</value>
				</exp>
				<exp bool_exp="true">
					<value>
						<color name="Controller: BG" red="205" green="205" blue="205"></color>
					</value>
				</exp>
				<pv_name>$(device):CLEAR</pv_name>
			</rule>
		</rules>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
