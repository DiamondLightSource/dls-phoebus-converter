<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Digitel MPC TSP Controller - $(device)</name>
	<x>754</x>
	<y>265</y>
	<width>260</width>
	<height>638</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>178</x>
		<y>607</y>
		<width>78</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="196" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM shell command</name>
		<actions>
			<action type="command">
				<description>Launch databrowser</description>
				<script file="EmbeddedPy">
					<text>from org.csstudio.opibuilder.scriptUtil import ScriptUtil

command_id="org.csstudio.trends.databrowser2.newWindow"
ScriptUtil.executeEclipseCommand(command_id, ['pvnames', '$(device):POWER'])</text>
				</script>
				<command>$(phoebus.install)/../phoebus.sh -resource "pv://?$(device):POWER&amp;app=databrowser</command>
			</action>
		</actions>
		<text>Graph</text>
		<x>8</x>
		<y>607</y>
		<width>77</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Related Display: FG" red="128" green="64" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM shell command</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>digitelMpcTspExpanded.bob</file>
				<target>replace</target>
			</action>
		</actions>
		<text>&lt; &gt;</text>
		<x>230</x>
		<y>584</y>
		<width>25</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="label" version="2.0.0">
		<name>EDM Label</name>
		<text>Settings</text>
		<x>158</x>
		<y>586</y>
		<width>51</width>
		<height>17</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Light Brown" red="196" green="128" blue="64"></color>
		</foreground_color>
		<background_color>
			<color name="White" red="255" green="255" blue="255"></color>
		</background_color>
		<vertical_alignment>1</vertical_alignment>
		<auto_size>true</auto_size>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color name="Light Brown" red="196" green="128" blue="64"></color>
		</border_color>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>Linking Container</name>
		<file>digitelMpcTspCore.bob</file>
		<width>261</width>
		<height>578</height>
		<resize>2</resize>
		<transparent>true</transparent>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
</display>