<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<width>500</width>
	<height>200</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="group" version="3.0.0">
		<name>$(desc)</name>
		<width>351</width>
		<height>86</height>
		<widget type="embedded" version="2.0.0">
			<name>$(desc)_Content</name>
			<file>tsp_embed.opi</file>
			<width>321</width>
			<height>56</height>
			<resize>2</resize>
			<transparent>true</transparent>
			<actions></actions>
		</widget>
	</widget>
</display>