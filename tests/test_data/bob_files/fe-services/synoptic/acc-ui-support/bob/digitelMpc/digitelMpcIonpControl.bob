		<widget type="action_button" version="2.0.0">
			<name>EDM Message Button</name>
			<bit>-1</bit>
			<x>8</x>
			<y>24</y>
			<width>65</width>
			<height>25</height>
			<off_label>Start</off_label>
			<off_color>
				<color red="240" green="240" blue="240"></color>
			</off_color>
			<on_label>Start</on_label>
			<on_color>
				<color red="192" green="192" blue="192"></color>
			</on_color>
			<show_led>false</show_led>
			<font>
				<font family="liberation sans" style="REGULAR" size="14.0"></font>
			</font>
			<foreground_color>
				<color name="Controller: FG" red="0" green="0" blue="196"></color>
			</foreground_color>
			<background_color>
				<color red="240" green="240" blue="240"></color>
			</background_color>
			<actions execute_as_one="true">
				<action type="write_pv">
					<description>Write PV</description>
					<pv_name>$(device):START</pv_name>
					<value>Start</value>
				</action>
			</actions>
			<rules>
				<rule name="visibleRule" prop_id="visible" out_exp="false">
					<exp bool_exp="pv0&gt;=0.0&amp;&amp; pv0&lt;1.0">
						<value>true</value>
					</exp>
					<exp bool_exp="true">
						<value>false</value>
					</exp>
					<pv_name>$(device):STARTING</pv_name>
				</rule>
				<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
					<exp bool_exp="pv0 == 1">
						<value>
							<color name="Button: On" red="190" green="190" blue="190"></color>
						</value>
					</exp>
					<exp bool_exp="true">
						<value>
							<color name="Controller: BG" red="205" green="205" blue="205"></color>
						</value>
					</exp>
					<pv_name>$(device):START</pv_name>
				</rule>
			</rules>
			<border_alarm_sensitive>false</border_alarm_sensitive>
			<mode>1</mode>
			<confirm_message>Are you sure you want to do this?</confirm_message>
			<text>Start</text>
		</widget>
		<widget type="action_button" version="3.0.0">
			<name>EDM Message Button</name>
			<actions execute_as_one="true">
				<action type="write_pv">
					<description>Write PV</description>
					<pv_name>$(pv_name)</pv_name>
					<value>Stop</value>
				</action>
			</actions>
			<pv_name>$(device):START</pv_name>
			<text>Stop</text>
			<x>80</x>
			<y>24</y>
			<width>65</width>
			<height>25</height>
			<font>
				<font family="liberation sans" style="REGULAR" size="14.0"></font>
			</font>
			<foreground_color>
				<color name="Controller: FG" red="0" green="0" blue="196"></color>
			</foreground_color>
			<background_color>
				<color red="240" green="240" blue="240"></color>
			</background_color>
			<rules>
				<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
					<exp bool_exp="pv0 == 1">
						<value>
							<color name="Grey 75%" red="192" green="192" blue="192"></color>
						</value>
					</exp>
					<exp bool_exp="true">
						<value>
							<color name="Controller: BG" red="205" green="205" blue="205"></color>
						</value>
					</exp>
					<pv_name>$(device):START</pv_name>
				</rule>
			</rules>
			<border_alarm_sensitive>false</border_alarm_sensitive>
		</widget>
