<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>Digitel MPC Ion Pump Controller - $(device)</name>
	<x>603</x>
	<y>296</y>
	<width>231</width>
	<height>336</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>8</grid_step_x>
	<grid_step_y>8</grid_step_y>
	<widget type="action_button" version="3.0.0">
		<name>EDM shell command</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>digitelMpcIonp2spExpanded.bob</file>
				<target>replace</target>
			</action>
		</actions>
		<text>^v</text>
		<x>16</x>
		<y>312</y>
		<width>25</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>Linking Container</name>
		<file>digitelMpcIonp2spCore.bob</file>
		<width>233</width>
		<height>306</height>
		<resize>2</resize>
		<transparent>true</transparent>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM shell command_1</name>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open Display</description>
				<file>../dlsPLC/NX102_interlock_small_detail.bob</file>
				<macros>
					<device>$(device):MPS_ILK</device>
					<interlock></interlock>
					<name>$(device):MPS_ILK</name>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>Interlock</text>
		<x>160</x>
		<y>310</y>
		<width>65</width>
		<height>25</height>
		<visible>false</visible>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Related Display: FG" red="128" green="64" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<rules>
			<rule name="visibilityRule" prop_id="visible" out_exp="false">
				<exp bool_exp="pv0&gt;-1">
					<value>true</value>
				</exp>
				<pv_name>$(device):MPS_ILK:INTERFACE</pv_name>
			</rule>
		</rules>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
</display>