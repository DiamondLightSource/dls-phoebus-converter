	<widget type="action_button" version="3.0.0">
		<name>EDM Exit Button</name>
		<actions>
			<action type="close_display">
				<description>Close display</description>
			</action>
		</actions>
		<text>Exit</text>
		<x>160</x>
		<y>278</y>
		<width>65</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Exit: FG" red="192" green="0" blue="192"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="action_button" version="3.0.0">
		<name>EDM related display</name>
		<actions>
			<action type="open_display">
				<description>Control</description>
				<file>./digitelMpcIonpControl.bob</file>
				<macros>
					<devive>$(device)</devive>
				</macros>
				<target>standalone</target>
			</action>
		</actions>
		<text>Control</text>
		<x>160</x>
		<y>214</y>
		<width>65</width>
		<height>25</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
