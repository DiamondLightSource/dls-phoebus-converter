		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="group" version="3.0.0">
		<name>0</name>
		<x>8</x>
		<y>214</y>
		<width>137</width>
		<height>57</height>
		<style>3</style>
		<foreground_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</foreground_color>
		<line_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</line_color>
		<transparent>true</transparent>
		<widget type="rectangle" version="2.0.0">
			<name>EDM Rectangle</name>
			<y>8</y>
			<width>137</width>
			<height>49</height>
			<line_width>1</line_width>
			<line_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</line_color>
			<background_color>
				<color name="Grey 65%" red="166" green="166" blue="166"></color>
			</background_color>
		</widget>
		<widget type="action_button" version="3.0.0">
			<name>EDM Message Button</name>
			<actions execute_as_one="true">
				<action type="write_pv">
					<description>Write PV</description>
					<pv_name>$(pv_name)</pv_name>
					<value>Stop</value>
				</action>
			</actions>
			<pv_name>$(device):START</pv_name>
			<text>Stop</text>
			<x>72</x>
			<y>24</y>
			<width>57</width>
			<height>25</height>
			<font>
				<font family="liberation sans" style="REGULAR" size="14.0"></font>
			</font>
			<foreground_color>
				<color name="Controller: FG" red="0" green="0" blue="192"></color>
			</foreground_color>
			<rules>
				<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
					<exp bool_exp="pv0 == 1">
						<value>
							<color name="Grey 75%" red="192" green="192" blue="192"></color>
						</value>
					</exp>
					<exp bool_exp="true">
						<value>
							<color name="Controller: BG" red="205" green="205" blue="205"></color>
						</value>
					</exp>
					<pv_name>$(device):START</pv_name>
				</rule>
			</rules>
			<border_alarm_sensitive>false</border_alarm_sensitive>
		</widget>
		<widget type="textupdate" version="2.0.0">
			<name>EDM Text Update</name>
			<pv_name>$(device):STARTING</pv_name>
			<x>8</x>
			<y>24</y>
			<width>57</width>
			<height>25</height>
			<font>
				<font family="liberation sans" style="BOLD" size="14.0"></font>
			</font>
			<foreground_color>
				<color name="Mid Green" red="0" green="192" blue="0"></color>
			</foreground_color>
			<background_color>
				<color name="Monitor: BG" red="64" green="64" blue="64"></color>
			</background_color>
			<transparent>true</transparent>
			<horizontal_alignment>1</horizontal_alignment>
			<border_alarm_sensitive>false</border_alarm_sensitive>
			<border_color>
				<color name="Mid Green" red="0" green="192" blue="0"></color>
			</border_color>
		</widget>
		<widget type="action_button" version="2.0.0">
			<name>EDM Message Button</name>
			<x>8</x>
			<y>24</y>
			<width>57</width>
			<height>25</height>
			<off_label>Start</off_label>
			<off_color>
				<color name="Button_Background" red="210" green="210" blue="210"></color>
			</off_color>
			<on_label>Start</on_label>
			<on_color>
				<color red="168" green="168" blue="168"></color>
			</on_color>
			<show_led>false</show_led>
			<font>
				<font family="liberation sans" style="REGULAR" size="14.0"></font>
			</font>
			<foreground_color>
				<color name="Controller: FG" red="0" green="0" blue="192"></color>
			</foreground_color>
			<actions execute_as_one="true">
				<action type="write_pv">
					<description>Write PV</description>
					<pv_name>$(device):START</pv_name>
					<value>Start</value>
				</action>
			</actions>
			<rules>
				<rule name="visibleRule" prop_id="visible" out_exp="false">
					<exp bool_exp="pv0&gt;=0.0&amp;&amp; pv0&lt;1.0">
						<value>true</value>
					</exp>
					<exp bool_exp="true">
						<value>false</value>
					</exp>
					<pv_name>$(device):STARTING</pv_name>
				</rule>
				<rule name="OnOffBackgroundRule" prop_id="background_color" out_exp="false">
					<exp bool_exp="pv0 == 1">
						<value>
							<color name="Button: On" red="190" green="190" blue="190"></color>
						</value>
					</exp>
					<exp bool_exp="true">
						<value>
							<color name="Controller: BG" red="205" green="205" blue="205"></color>
						</value>
					</exp>
					<pv_name>$(device):START</pv_name>
				</rule>
			</rules>
			<border_alarm_sensitive>false</border_alarm_sensitive>
			<mode>1</mode>
			<text>Start</text>
		</widget>
		<widget type="label" version="2.0.0">
			<name>EDM Label</name>
			<text>Control</text>
			<width>48</width>
			<height>16</height>
			<font>
				<font family="liberation sans" style="REGULAR" size="12.0"></font>
			</font>
			<foreground_color>
				<color name="Grey 90%" red="230" green="230" blue="230"></color>
			</foreground_color>
			<background_color>
				<color name="Grey 50%" red="128" green="128" blue="128"></color>
			</background_color>
			<transparent>false</transparent>
			<horizontal_alignment>1</horizontal_alignment>
			<vertical_alignment>1</vertical_alignment>
			<border_color>
				<color name="Grey 90%" red="230" green="230" blue="230"></color>
			</border_color>
		</widget>
		<widget type="rectangle" version="2.0.0">
			<name>EDM Rectangle</name>
			<width>49</width>
			<height>17</height>
			<line_width>1</line_width>
			<line_color>
				<color name="Black" red="0" green="0" blue="0"></color>
			</line_color>
			<background_color>
				<color name="Grey 75%" red="192" green="192" blue="192"></color>
			</background_color>
			<transparent>true</transparent>
		</widget>
	</widget>
