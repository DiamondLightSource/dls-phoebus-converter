<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<width>30</width>
	<height>95</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>5</grid_step_x>
	<grid_step_y>5</grid_step_y>
	<widget type="progressbar" version="2.0.0">
		<name>Bar</name>
		<pv_name>$(dom)-VA-GAUGE-$(id):P</pv_name>
		<x>5</x>
		<width>20</width>
		<height>70</height>
		<fill_color>
			<color name="Monitor: FG" red="96" green="255" blue="96"></color>
		</fill_color>
		<background_color>
			<color name="Grey 65%" red="166" green="166" blue="166"></color>
		</background_color>
		<horizontal>false</horizontal>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<limits_from_pv>false</limits_from_pv>
		<minimum>1.0E-12</minimum>
		<maximum>10000.0</maximum>
		<log_scale>true</log_scale>
	</widget>
	<widget type="textupdate" version="2.0.0">
		<name>Pressure</name>
		<pv_name>$(dom)-VA-GAUGE-$(id):P</pv_name>
		<x>5</x>
		<y>5</y>
		<width>20</width>
		<height>65</height>
		<foreground_color>
			<color name="Text: FG" red="0" green="0" blue="0"></color>
		</foreground_color>
		<background_color>
			<color name="Monitor: BG" red="64" green="64" blue="64"></color>
		</background_color>
		<transparent>true</transparent>
		<format>2</format>
		<precision>1</precision>
		<show_units>false</show_units>
		<horizontal_alignment>1</horizontal_alignment>
		<wrap_words>false</wrap_words>
		<rotation_step>3</rotation_step>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="polyline" version="2.0.0">
		<name>Line</name>
		<macros>
			<pv_name></pv_name>
		</macros>
		<x>15</x>
		<y>70</y>
		<width>1</width>
		<height>6</height>
		<points>
			<point x="0.0" y="0.0"></point>
			<point x="0.0" y="5.0"></point>
		</points>
		<line_width>2</line_width>
		<line_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</line_color>
		<actions></actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
	</widget>
	<widget type="symbol" version="2.0.0">
		<name>Icon</name>
		<pv_name>$(dom)-VA-GAUGE-$(id):P.SEVR</pv_name>
		<symbols>
			<symbol>symbol/gauge 0.svg</symbol>
		</symbols>
		<x>5</x>
		<y>75</y>
		<width>20</width>
		<height>20</height>
		<background_color>
			<color name="Canvas" red="200" green="200" blue="200"></color>
		</background_color>
		<actions execute_as_one="true">
			<action type="open_display">
				<description>Open detail screen</description>
				<file>gauge_detail.bob</file>
				<target>replace</target>
			</action>
		</actions>
		<tooltip>$(pv_name)
$(pv_value)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<preserve_ratio>false</preserve_ratio>
	</widget>
	<widget type="label" version="2.0.0">
		<name>Label</name>
		<text>$(id)</text>
		<y>75</y>
		<width>30</width>
		<font>
			<font name="Label Small" family="Arial" style="REGULAR" size="9.900990099009901"></font>
		</font>
		<horizontal_alignment>1</horizontal_alignment>
		<vertical_alignment>1</vertical_alignment>
		<wrap_words>false</wrap_words>
		<actions></actions>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
</display>