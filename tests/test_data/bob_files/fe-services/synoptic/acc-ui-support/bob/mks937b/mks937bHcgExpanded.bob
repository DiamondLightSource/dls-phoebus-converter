<?xml version="1.0" encoding="utf-8"?>
<display version="2.0.0">
	<name>MKS 937B Inverted Magnetron Gauge - $(device)</name>
	<x>281</x>
	<y>196</y>
	<width>368</width>
	<height>840</height>
	<background_color>
		<color name="Canvas" red="200" green="200" blue="200"></color>
	</background_color>
	<actions></actions>
	<grid_step_x>4</grid_step_x>
	<grid_step_y>4</grid_step_y>
	<widget type="action_button" version="3.0.0">
		<name>EDM shell command</name>
		<actions>
			<action type="open_display">
				<description>Open Display</description>
				<file>mks937bHcg.bob</file>
				<target>replace</target>
			</action>
		</actions>
		<text>^v</text>
		<x>4</x>
		<y>496</y>
		<width>25</width>
		<height>21</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<tooltip>$(actions)</tooltip>
		<border_alarm_sensitive>false</border_alarm_sensitive>
	</widget>
	<widget type="choice" version="2.0.0">
		<name>EDM choice  Button</name>
		<pv_name>loc://enum1&lt;VEnum&gt;(0, "Readback", "Edit")</pv_name>
		<x>4</x>
		<y>524</y>
		<width>220</width>
		<height>20</height>
		<font>
			<font family="liberation sans" style="REGULAR" size="14.0"></font>
		</font>
		<foreground_color>
			<color name="Controller: FG" red="0" green="0" blue="196"></color>
		</foreground_color>
		<background_color>
			<color name="Controller: BG" red="205" green="205" blue="205"></color>
		</background_color>
		<selected_color>
			<color name="Grey 75%" red="192" green="192" blue="192"></color>
		</selected_color>
		<actions></actions>
		<border_alarm_sensitive>false</border_alarm_sensitive>
		<items>
			<item>Item 1</item>
			<item>Item 2</item>
		</items>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>EDM linkingContainer</name>
		<x>4</x>
		<y>548</y>
		<width>364</width>
		<height>292</height>
		<resize>4</resize>
		<transparent>true</transparent>
		<actions></actions>
		<scripts>
			<script file="EmbeddedJs">
				<text>importPackage(Packages.org.csstudio.opibuilder.scriptUtil);
var pv0 = PVUtil.getLong(pvs[0]);
if(pv0==0){
var macroInput = DataUtil.createMacrosInput(true);
widget.setPropertyValue("macros", macroInput);
widget.setPropertyValue("opi_file","./mks937bHcgIlksReadback_embedded.opi");
}
else if(pv0==1){
var macroInput = DataUtil.createMacrosInput(true);
widget.setPropertyValue("macros", macroInput);
widget.setPropertyValue("opi_file","mks937bHcgIlks_embedded.opi");
}</text>
				<pv_name>loc://enum1</pv_name>
			</script>
		</scripts>
		<border_color>
			<color red="0" green="128" blue="255"></color>
		</border_color>
	</widget>
	<widget type="embedded" version="2.0.0">
		<name>Linking Container</name>
		<file>mks937bHcgCore.bob</file>
		<width>241</width>
		<height>494</height>
		<resize>2</resize>
		<transparent>true</transparent>
		<actions></actions>
		<border_color>
			<color name="Black" red="0" green="0" blue="0"></color>
		</border_color>
	</widget>
</display>