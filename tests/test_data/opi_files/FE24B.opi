      <rule name="symbol_single_pv" prop_id="image_index" out_exp="true">
        <exp bool_exp="pvSev0==-1">
          <value>0</value>
        </exp>
        <exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;0.0">
          <value>0</value>
        </exp>
        <exp bool_exp="pv0&gt;=0.0&amp;&amp;pv0&lt;1.0">
          <value>0</value>
        </exp>
        <exp bool_exp="pv0&gt;=1.0&amp;&amp;pv0&lt;2.0">
          <value>1</value>
        </exp>
        <exp bool_exp="pv0&gt;=2.0&amp;&amp;pv0&lt;3.0">
          <value>2</value>
        </exp>
        <exp bool_exp="pv0&gt;=3.0&amp;&amp;pv0&lt;4.0">
          <value>3</value>
        </exp>
        <exp bool_exp="pv0&gt;=4.0&amp;&amp;pv0&lt;5.0">
          <value>4</value>
        </exp>
        <exp bool_exp="pv0&gt;=5.0&amp;&amp;pv0&lt;6.0">
          <value>5</value>
        </exp>
        <exp bool_exp="pv0&gt;=6.0&amp;&amp;pv0&lt;7.0">
          <value>5</value>
        </exp>
        <exp bool_exp="pv0&gt;=7.0&amp;&amp;pv0&lt;8.0">
          <value>5</value>
        </exp>
        <exp bool_exp="pv0&gt;=8.0&amp;&amp;pv0&lt;9.0">
          <value>5</value>
        </exp>
        <exp bool_exp="true">
          <value>0</value>
        </exp>
        <pv trig="true">$(pv_name)</pv>
      </rule>
    </rules>
